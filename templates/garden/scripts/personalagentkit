#!/usr/bin/env bash
# personalagentkit — run a goal and record what happened
#
# Usage:
#   ./personalagentkit run <goal-file>
#   ./personalagentkit run goals/002-something.md
#
# Produces:
#   runs/<goal-id>/meta.json   — structured run record
#   runs/<goal-id>/_stdout.md   — agent output
#
# Principles honored:
#   P2: meta.json is schema-validated structure
#   P5: every run produces a record before the agent speaks
#   P6: cost fields are required in meta.json at completion
#   P7: reflection obligations are recorded in meta.json and stated in the prompt

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SCHEMA="$REPO_ROOT/schema/run.schema.json"

# ── helpers ───────────────────────────────────────────────────────────────────

die() { echo "personalagentkit: $*" >&2; exit 1; }

require() {
  command -v "$1" &>/dev/null || die "required tool not found: $1"
}

github_usage() {
  cat <<'HELP'
Usage:
  ./scripts/personalagentkit publish-github [--remote <name>] [--head <branch>] [--base <branch>]
                                            [--owner <owner>] [--repo <repo>]
                                            [--title <title>] [--body <body>] [--draft]

Config:
  Reads durable defaults from config/github.env.
  Reads the GitHub token from secrets/github-token.txt.

Behavior:
  Pushes the current branch over HTTPS with non-interactive git.
  Opens a pull request through the GitHub REST API with curl.
  If the token file is missing or empty, prints a clear skip message and exits 0.
HELP
}

github_config_file() {
  printf '%s\n' "${PAK_GITHUB_CONFIG_FILE:-$REPO_ROOT/config/github.env}"
}

github_token_file() {
  printf '%s\n' "${PAK_GITHUB_TOKEN_FILE:-$REPO_ROOT/secrets/github-token.txt}"
}

github_load_config() {
  local path="$1"
  [[ -f "$path" ]] || die "missing GitHub config file: $path (see config/github.env.example)"
  set -a
  # shellcheck disable=SC1090
  . "$path"
  set +a
}

github_normalize_bool() {
  case "${1:-false}" in
    1|true|TRUE|yes|YES|on|ON) echo "true" ;;
    0|false|FALSE|no|NO|off|OFF|"") echo "false" ;;
    *) die "invalid boolean value: $1" ;;
  esac
}

github_current_branch() {
  git rev-parse --abbrev-ref HEAD
}

github_read_token() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "personalagentkit: skipping publish-github: missing GitHub token at $path. Add a token and rerun."
    return 10
  fi

  local token
  token="$(tr -d '\r\n' < "$path")"
  if [[ -z "$token" ]]; then
    echo "personalagentkit: skipping publish-github: GitHub token file is empty at $path. Add a token and rerun."
    return 10
  fi

  GITHUB_READ_TOKEN_RESULT="$token"
  return 0
}

github_push_branch() {
  local remote="$1"
  local head_branch="$2"
  local token="$3"
  local askpass
  askpass="$(mktemp)"
  cat > "$askpass" <<'EOF'
#!/usr/bin/env bash
case "${1:-}" in
  *Username*) printf '%s\n' "x-access-token" ;;
  *) printf '%s\n' "$GITHUB_TOKEN_FOR_PUSH" ;;
esac
EOF
  chmod 700 "$askpass"

  local origin_url
  origin_url="$(git remote get-url "$remote")"
  [[ "$origin_url" == https://* ]] || die "remote '$remote' must use HTTPS, found: $origin_url"

  local git_status=0
  GIT_TERMINAL_PROMPT=0 \
  GIT_ASKPASS="$askpass" \
  GITHUB_TOKEN_FOR_PUSH="$token" \
    git push "$remote" "HEAD:refs/heads/$head_branch" || git_status=$?

  rm -f "$askpass"
  return "$git_status"
}

github_create_pr() {
  local api_base_url="$1"
  local owner="$2"
  local repo="$3"
  local token="$4"
  local request_json="$5"

  curl \
    --silent \
    --show-error \
    --fail-with-body \
    --request POST \
    --url "$api_base_url/repos/$owner/$repo/pulls" \
    --header "Accept: application/vnd.github+json" \
    --header "Authorization: Bearer $token" \
    --header "X-GitHub-Api-Version: 2022-11-28" \
    --header "Content-Type: application/json" \
    --data "$request_json"
}

# flock shim for macOS (no flock without brew install util-linux).
# When flock is unavailable, the subshell still runs — just without cross-process locking.
if ! command -v flock &>/dev/null; then
  flock() { return 0; }
fi

iso_now() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

iso_to_epoch() {
  # Convert ISO 8601 timestamp to epoch seconds (portable: BSD + GNU)
  local ts="$1"
  date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" "+%s" 2>/dev/null \
    || date -u -d "$ts" "+%s" 2>/dev/null \
    || echo 0
}

normalize_status() {
  case "${1:-}" in
    completed) echo "success" ;;
    failed) echo "failure" ;;
    *) echo "${1:-}" ;;
  esac
}

is_terminal_status() {
  case "$(normalize_status "${1:-}")" in
    success|failure|killed|abandoned) return 0 ;;
    *) return 1 ;;
  esac
}

legacy_status_summary() {
  local legacy_found=()
  local meta raw
  for meta in \
      "$REPO_ROOT/runs"/*/meta.json \
      "$REPO_ROOT/plants"/*/runs/*/meta.json; do
    [[ -f "$meta" ]] || continue
    raw=$(jq -r '.status // ""' "$meta" 2>/dev/null)
    case "$raw" in
      completed|failed)
        legacy_found+=("$raw")
        ;;
    esac
  done

  if [[ "${#legacy_found[@]}" -eq 0 ]]; then
    echo "Legacy compatibility: reading completed->success and failed->failure for older records; new runs write only canonical statuses."
    return
  fi

  local unique=""
  local item
  for item in "${legacy_found[@]}"; do
    case " $unique " in
      *" $item "*) ;;
      *) unique="${unique:+$unique, }$item" ;;
    esac
  done
  echo "Legacy compatibility: reading completed->success and failed->failure for older records. Present in current run records: ${unique}."
}

operator_first_name_from_charter() {
  local charter="$REPO_ROOT/../shared/charter.md"
  [[ -f "$charter" ]] || return 0

  awk '
    /^## Operator[[:space:]]*$/ { in_operator=1; next }
    /^## / && in_operator { exit }
    in_operator && NF { print; exit }
  ' "$charter" \
    | head -1 \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/^[^a-z0-9-]*//; s/[^a-z0-9-].*$//'
}

is_operator_outbox_file() {
  local file_name
  file_name=$(basename "$1")
  [[ "$file_name" =~ ^[0-9]+-to-operator\.md$ ]] && return 0

  local operator_first_name
  operator_first_name=$(operator_first_name_from_charter)
  [[ -n "$operator_first_name" ]] || return 1
  [[ "$file_name" =~ ^[0-9]+-to-${operator_first_name}\.md$ ]]
}

surface_pending_operator_mail() {
  local prefix="${1:-telos}"
  local inbox_dir="$REPO_ROOT/inbox"
  [[ -d "$inbox_dir" ]] || return 0

  local any_pending=false
  local msg
  shopt -s nullglob
  for msg in "$inbox_dir"/*.md; do
    is_operator_outbox_file "$msg" || continue
    local base nnn reply
    base=$(basename "$msg" .md)
    nnn=$(echo "$base" | grep -oE '^[0-9]+' | head -1)
    reply="$inbox_dir/${nnn}-reply.md"
    if [[ ! -f "$reply" ]]; then
      if [[ "$any_pending" == "false" ]]; then
        echo "$prefix: ── inbox ────────────────────────────────────────────────"
        any_pending=true
      fi
      echo "$prefix: pending: $msg"
      echo "---"
      cat "$msg"
      echo "---"
    fi
  done
  shopt -u nullglob
}

# ── driver config ─────────────────────────────────────────────────────────────

PAK_DEFAULT_DRIVER="${PAK_DRIVER:-$(cat "$REPO_ROOT/.personalagentkit-driver" 2>/dev/null || echo claude)}"
PAK_DEFAULT_MODEL="${PAK_MODEL:-}"
PAK_DRIVER=""
PAK_MODEL=""
_driver_bin=""
_driver_model=""

resolve_driver_config() {
  local requested_driver="${1:-}"
  local requested_model="${2:-}"
  local cmd=(python3 -m runner.host resolve)
  [[ -n "$requested_driver" ]] && cmd+=(--driver "$requested_driver")
  [[ -n "$requested_model" ]] && cmd+=(--model "$requested_model")

  local resolved_json
  resolved_json=$(cd "$REPO_ROOT" && "${cmd[@]}") || die "driver resolution failed"

  PAK_DRIVER=$(echo "$resolved_json" | jq -r '.driver')
  PAK_MODEL=$(echo "$resolved_json" | jq -r '.model')
  _driver_bin=$(echo "$resolved_json" | jq -r '.binary')
  _driver_model="$PAK_MODEL"
}

goal_id_from_file() {
  # goals/001-bootstrap.md → 001-bootstrap
  basename "$1" .md
}

goal_title_from_file() {
  local goal_file="$1"
  awk '
    /^#/ {
      sub(/^#[[:space:]]*/, "", $0)
      print
      exit
    }
  ' "$goal_file" 2>/dev/null || true
}

goal_run_pointer_path() {
  local goal_file="$1"
  printf '%s\n' "${goal_file%.md}.run"
}

expected_run_dir_for_goal() {
  local goal_file="$1"
  local goal_id assigned_to
  goal_id=$(goal_id_from_file "$goal_file")
  assigned_to=$(parse_goal_meta "$goal_file" assigned_to)

  if [[ -n "$assigned_to" ]]; then
    printf 'plants/%s/runs/%s\n' "$assigned_to" "$goal_id"
  else
    printf 'runs/%s\n' "$goal_id"
  fi
}

latest_agent_message() {
  local run_dir="$1"
  local events_file="$run_dir/events.jsonl"
  [[ -f "$events_file" ]] || return 0

  jq -r -s '
    map(select(.type == "item.completed" and (.item.type // "") == "agent_message"))
    | last
    | .item.text // empty
  ' "$events_file" 2>/dev/null \
    | tr '\n' ' ' \
    | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//'
}

run_reader_artifacts() {
  local run_dir="$1"
  local found=false
  local artifact base

  shopt -s nullglob
  for artifact in "$run_dir"/*.md; do
    [[ -f "$artifact" ]] || continue
    base=$(basename "$artifact")
    case "$base" in
      README.md|prompt-attempt-*.md) continue ;;
    esac
    printf '%s\n' "$base"
    found=true
  done
  shopt -u nullglob

  [[ "$found" == "true" ]] || true
}

write_run_transcript() {
  local run_dir="$1"
  local meta="$run_dir/meta.json"
  local events_file="$run_dir/events.jsonl"
  local transcript="$run_dir/transcript.md"
  [[ -f "$meta" && -f "$events_file" ]] || return 0

  local status
  status=$(jq -r '.status // "unknown"' "$meta" 2>/dev/null)
  status=$(normalize_status "$status")
  [[ "$status" == "running" ]] && return 0
  python3 "$REPO_ROOT/runner/transcript.py" render "$run_dir" > /dev/null
  [[ -f "$transcript" ]] || return 1
}

write_goal_run_pointer() {
  local goal_file="$1"
  local goal_path="$REPO_ROOT/$goal_file"
  [[ -f "$goal_path" ]] || return 0

  local pointer_path run_dir_rel run_dir_abs status goal_title assigned_to
  pointer_path=$(goal_run_pointer_path "$goal_path")
  run_dir_rel=$(expected_run_dir_for_goal "$goal_path")
  run_dir_abs="$REPO_ROOT/$run_dir_rel"
  goal_title=$(goal_title_from_file "$goal_path")
  assigned_to=$(parse_goal_meta "$goal_path" assigned_to)

  if [[ -f "$run_dir_abs/meta.json" ]]; then
    status=$(jq -r '.status // "running"' "$run_dir_abs/meta.json" 2>/dev/null)
    status=$(normalize_status "$status")
  else
    status="queued"
  fi

  {
    echo "# Run Pointer"
    echo
    [[ -n "$goal_title" ]] && echo "- Goal: $goal_title"
    echo "- Goal file: \`$goal_file\`"
    if [[ -n "$assigned_to" ]]; then
      echo "- Assigned plant: \`$assigned_to\`"
    else
      echo "- Assigned plant: root"
    fi
    echo "- Status: \`$status\`"
    echo "- Run directory: \`$run_dir_rel\`"
    echo "- Open first when the run exists: \`$run_dir_rel/README.md\`"
    if [[ "$status" == "queued" ]]; then
      echo "- Queue contract: this pointer is the reader-facing state file until the run directory exists."
    else
      echo "- Reader contract: once execution starts, the run directory's \`README.md\` is the authoritative first file to open."
    fi
  } > "$pointer_path"
}

write_run_readme() {
  local run_dir="$1"
  local meta="$run_dir/meta.json"
  [[ -f "$meta" ]] || return 0

  local run_id goal_file status started_at completed_at goal_type requires_reflection goal_title
  run_id=$(jq -r '.run_id // ""' "$meta" 2>/dev/null)
  goal_file=$(jq -r '.goal_file // ""' "$meta" 2>/dev/null)
  status=$(jq -r '.status // "unknown"' "$meta" 2>/dev/null)
  status=$(normalize_status "$status")
  started_at=$(jq -r '.started_at // ""' "$meta" 2>/dev/null)
  completed_at=$(jq -r '.completed_at // empty' "$meta" 2>/dev/null)
  goal_type=$(jq -r '.goal_type // empty' "$meta" 2>/dev/null)
  requires_reflection=$(jq -r '.requires_reflection // false' "$meta" 2>/dev/null)
  goal_title=$(goal_title_from_file "$REPO_ROOT/$goal_file")

  local latest_progress
  latest_progress=$(latest_agent_message "$run_dir")

  local cost_value artifact_lines
  cost_value=$(preferred_cost_from_meta "$meta")
  artifact_lines=$(run_reader_artifacts "$run_dir" | sort || true)

  {
    echo "# Run Overview"
    echo
    [[ -n "$goal_title" ]] && echo "- Goal: $goal_title"
    echo "- Run id: \`$run_id\`"
    [[ -n "$goal_file" ]] && echo "- Goal file: \`$goal_file\`"
    echo "- Status: \`$status\`"
    [[ -n "$goal_type" ]] && echo "- Goal type: \`$goal_type\`"
    [[ -n "$started_at" ]] && echo "- Started: \`$started_at\`"
    [[ -n "$completed_at" ]] && echo "- Completed: \`$completed_at\`"
    if [[ "$cost_value" != "null" ]]; then
      echo "- Cost: \`$cost_value\` USD"
    fi
    echo
    echo "Open this file first. The JSON and JSONL files in this directory remain the supporting evidence."
    echo
    if [[ "$status" == "running" ]]; then
      echo "## Current State"
      if [[ -n "$latest_progress" ]]; then
        echo
        echo "$latest_progress"
      else
        echo
        echo "No agent message has been recorded yet."
      fi
      echo
      echo "Expected guaranteed artifacts on completion:"
      echo "- \`_stdout.md\` for the run summary"
      if [[ "$requires_reflection" == "true" ]]; then
        echo "- \`reflection.md\` because this run's reflection contract requires it on success"
      fi
    else
      echo "## What To Read Next"
      if [[ -n "$artifact_lines" ]]; then
        printf '%s\n' "$artifact_lines" | while IFS= read -r artifact; do
          [[ -n "$artifact" ]] || continue
          echo "- \`$artifact\`"
        done
      else
        echo "- No reader-facing markdown artifacts are present beyond this file yet."
      fi
    fi
    echo
    echo "## Evidence Files"
    echo "- \`meta.json\` for structured status, timing, and cost"
    echo "- \`events.jsonl\` for the raw event transcript"
    if [[ -f "$run_dir/checkpoint.jsonl" ]]; then
      echo "- \`checkpoint.jsonl\` for lifecycle checkpoints"
    fi
    if [[ -f "$run_dir/stderr.txt" ]]; then
      echo "- \`stderr.txt\` for driver stderr"
    fi
  } > "$run_dir/README.md"
}

classify_goal_type() {
  local slug="${1:-}"
  slug=$(basename "$slug" .md)
  slug="${slug,,}"

  if [[ "$slug" =~ ^[0-9]+[-_]+(.+)$ ]]; then
    slug="${BASH_REMATCH[1]}"
  fi

  local IFS='-_'
  read -r -a goal_tokens <<< "$slug"
  local first_token="${goal_tokens[0]:-}"
  local last_token="${goal_tokens[${#goal_tokens[@]}-1]:-}"

  case "$first_token" in
    integrate) echo "integrate" ;;
    retrospective) echo "retrospective" ;;
    tend) echo "tend" ;;
    genesis) echo "genesis" ;;
    dispatch) echo "dispatch" ;;
    review) echo "review" ;;
    spike) echo "spike" ;;
    fix) echo "fix" ;;
    build|"") echo "build" ;;
    *)
      if [[ "$last_token" == "spike" ]]; then
        echo "spike"
      else
        echo "build"
      fi
      ;;
  esac
}

goal_type_requires_reflection() {
  case "${1:-}" in
    build|fix|review|tend|retrospective) echo "true" ;;
    *) echo "false" ;;
  esac
}

reflection_contract_prompt() {
  local goal_type="${1:-build}"
  local requires_reflection="${2:-false}"
  if [[ "$requires_reflection" == "true" ]]; then
    cat <<EOF

# Reflection Contract

This run is classified as a \`$goal_type\` run.
If it succeeds, you must write \`reflection.md\` in the run directory before exiting.
EOF
  else
    cat <<EOF

# Reflection Contract

This run is classified as a \`$goal_type\` run.
\`reflection.md\` is not required by the run ledger contract for this run type unless the goal text explicitly asks for it.
EOF
  fi
}

parse_goal_meta() {
  # Usage: parse_goal_meta <goal-file> <field>
  # field: assigned_to | depends_on | submitted_by | driver | model
  # Returns the field value, or empty string if not present or no frontmatter.
  local goal_file="$1" field="$2"
  [[ -f "$goal_file" ]] || { echo ""; return; }
  local first_line
  first_line=$(head -1 "$goal_file")
  [[ "$first_line" == "---" ]] || { echo ""; return; }
  # Extract lines between first --- and second ---, strip the closing ---
  sed -n '2,/^---$/p' "$goal_file" | grep -v '^---$' \
    | grep "^${field}:" | sed "s/^${field}:[[:space:]]*//" | head -1 || true
}

resolve_goal_routing() {
  local goal_file="$1"
  local explicit_driver="${2:-}"
  local explicit_model="${3:-}"
  local goal_driver goal_model resolved_driver resolved_model

  goal_driver=$(parse_goal_meta "$goal_file" driver)
  goal_model=$(parse_goal_meta "$goal_file" model)
  resolved_driver="${explicit_driver:-${goal_driver:-$PAK_DEFAULT_DRIVER}}"
  resolved_model="${explicit_model:-${goal_model:-$PAK_DEFAULT_MODEL}}"

  resolve_driver_config "$resolved_driver" "$resolved_model"
}

preferred_cost_from_meta() {
  local meta="$1"
  jq -r '
    if (.cost | type) == "number" then .cost
    elif (.cost | type) != "object" then "null"
    else .cost.actual_usd // .cost.estimated_usd // "null"
    end
  ' "$meta" 2>/dev/null
}

is_dep_satisfied() {
  # Usage: is_dep_satisfied <dep-slug>
  # dep-slug may be "NNN-slug" (exact match) or "slug" (match by suffix *-slug)
  # Returns 0 if a successful run matching the slug exists, 1 otherwise.
  local dep="$1"
  local pattern
  if [[ "$dep" =~ ^[0-9] ]]; then
    pattern="${dep}"
  else
    pattern="*-${dep}"
  fi
  # Check root runs
  local run_dir
  for run_dir in "$REPO_ROOT/runs"/${pattern}/; do
    [[ -f "${run_dir}meta.json" ]] || continue
    local st
    st=$(jq -r '.status // ""' "${run_dir}meta.json" 2>/dev/null)
    st=$(normalize_status "$st")
    [[ "$st" == "success" ]] && return 0
  done
  # Check plant runs
  local plant_path
  for plant_path in "$REPO_ROOT/plants"/*/; do
    [[ -d "$plant_path" ]] || continue
    for run_dir in "${plant_path}runs"/${pattern}/; do
      [[ -f "${run_dir}meta.json" ]] || continue
      local st
      st=$(jq -r '.status // ""' "${run_dir}meta.json" 2>/dev/null)
      st=$(normalize_status "$st")
      [[ "$st" == "success" ]] && return 0
    done
  done
  return 1
}

current_attempt_number() {
  local run_dir="$1"
  local prompt_file last
  last=""
  shopt -s nullglob
  for prompt_file in "$run_dir"/prompt-attempt-*.md; do
    last="$prompt_file"
  done
  shopt -u nullglob
  if [[ -z "$last" ]]; then
    echo 0
    return
  fi

  local stem="${last##*/prompt-attempt-}"
  stem="${stem%.md}"
  [[ "$stem" =~ ^[0-9]+$ ]] && echo $((10#$stem)) || echo 0
}

next_attempt_number() {
  local run_dir="$1"
  echo $(( $(current_attempt_number "$run_dir") + 1 ))
}

attempt_label() {
  printf "%02d" "$1"
}

prompt_artifact_path() {
  local run_dir="$1" attempt="$2"
  printf '%s/prompt-attempt-%s.md\n' "$run_dir" "$(attempt_label "$attempt")"
}

append_checkpoint() {
  local run_dir="$1" event="$2" note="${3:-}"
  jq -cn \
    --arg ts "$(iso_now)" \
    --arg event "$event" \
    --argjson attempt "$(current_attempt_number "$run_dir")" \
    --arg note "$note" \
    '{ts: $ts, event: $event, attempt: $attempt}
     | if $note != "" then . + {note: $note} else . end' >> "$run_dir/checkpoint.jsonl"
}

build_run_prompt() {
  local goal_file="$1" base_dir="$2" goal_type="$3" requires_reflection="$4" extra_context="${5:-}"
  local motivation goal_content memory_section
  motivation=$(cat "$base_dir/MOTIVATION.md")
  goal_content=$(cat "$REPO_ROOT/$goal_file")

  memory_section=""
  if [[ -f "$base_dir/memory/MEMORY.md" ]]; then
    local memory_content
    memory_content=$(cat "$base_dir/memory/MEMORY.md")
    memory_section=$(cat <<MEMORY

---

# Memory

$memory_content
MEMORY
)
  fi

  cat <<PROMPT
You are a capable agent working on a goal within the PersonalAgentKit system.

# Motivation

$motivation
$memory_section

---

# Goal

$goal_content
$(reflection_contract_prompt "$goal_type" "$requires_reflection")
$extra_context

---

Your working directory is $base_dir. Begin.
PROMPT
}

write_prompt_artifact() {
  local run_dir="$1" attempt="$2" prompt="$3"
  local prompt_path
  prompt_path=$(prompt_artifact_path "$run_dir" "$attempt")
  printf '%s\n' "$prompt" > "$prompt_path"
}

find_run_dir_by_id() {
  local run_id="$1"
  local candidate
  for candidate in "$REPO_ROOT/runs/$run_id" "$REPO_ROOT/plants"/*/runs/"$run_id"; do
    [[ -d "$candidate" && -f "$candidate/meta.json" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

archive_attempt_artifacts() {
  local run_dir="$1" attempt="$2"
  local archive_dir="$run_dir/attempts/attempt-$(attempt_label "$attempt")"
  mkdir -p "$archive_dir"

  local artifact
  for artifact in events.jsonl _stdout.md stderr.txt meta.json transcript.md; do
    [[ -f "$run_dir/$artifact" ]] || continue
    cp "$run_dir/$artifact" "$archive_dir/$artifact"
    [[ "$artifact" == "meta.json" ]] || rm -f "$run_dir/$artifact"
  done

  local prompt_path
  prompt_path=$(prompt_artifact_path "$run_dir" "$attempt")
  [[ -f "$prompt_path" ]] && cp "$prompt_path" "$archive_dir/$(basename "$prompt_path")"

  printf '%s\n' "$archive_dir"
}

resume_context_block() {
  local run_dir="$1" prior_attempt="$2" archive_dir="$3"
  local latest_checkpoint prior_status prior_cost
  latest_checkpoint=$(tail -n 1 "$run_dir/checkpoint.jsonl" 2>/dev/null || true)
  prior_status=$(jq -r '.status // "unknown"' "$archive_dir/meta.json" 2>/dev/null)
  prior_cost=$(preferred_cost_from_meta "$archive_dir/meta.json")

  cat <<EOF

## Resume Context

This run is being resumed from local artifacts after attempt $(attempt_label "$prior_attempt") ended with status \`$prior_status\`.

- Resume basis: local artifacts only
- Provider session continuation: none
- Fresh provider call required: yes
- Preserved artifacts: \`checkpoint.jsonl\`, \`attempts/attempt-$(attempt_label "$prior_attempt")/\`, prior prompt artifact
- Recomputed artifacts for this attempt: \`events.jsonl\`, \`_stdout.md\`, \`stderr.txt\`, \`transcript.md\`
- Current workspace basis: whatever is now present on disk in the working directory
- Prior visible cost: $prior_cost USD
- Latest checkpoint record: \`$latest_checkpoint\`

Continue from the preserved local state. Do not claim to have resumed hidden provider state. If earlier work is uncertain or incomplete, say what was preserved and what you are recomputing in this fresh call.
EOF
}

reset_meta_for_resume() {
  local meta="$1" resumed_at="$2" prior_attempt="$3"
  jq \
    --arg resumed_at "$resumed_at" \
    --argjson prior_attempt "$prior_attempt" \
    '.status = "running"
   | .completed_at = null
   | .cost = null
   | .outputs = []
   | .notes = ("Resumed from attempt " + ($prior_attempt|tostring) + " using local artifacts only; provider session continuation = false.")
   | .num_turns = null
   | .duration_ms = null
   | .resume_count = ((.resume_count // 0) + 1)
   | .last_resumed_at = $resumed_at
   | .resumed_from_attempt = $prior_attempt
   | .resume_strategy = "fresh-provider-call-from-local-artifacts"' \
    "$meta" > "$meta.tmp" && mv "$meta.tmp" "$meta"
}

write_resume_artifact() {
  local run_dir="$1" prior_attempt="$2" archive_dir="$3"
  local prior_cost total_cost status last_attempt_cost
  prior_cost=$(preferred_cost_from_meta "$archive_dir/meta.json")
  total_cost=$(preferred_cost_from_meta "$run_dir/meta.json")
  last_attempt_cost=$(jq -r '
    (.last_attempt_cost.actual_usd // .last_attempt_cost.estimated_usd // empty)
    | if . == "" then "0.0000" else tostring end
  ' "$run_dir/meta.json" 2>/dev/null)
  status=$(jq -r '.status // "unknown"' "$run_dir/meta.json" 2>/dev/null)

  cat > "$run_dir/resume.md" <<EOF
# Resumption Record

- Basis: local artifacts only
- Provider continuation: fresh call
- Preserved from attempt $(attempt_label "$prior_attempt"): \`$archive_dir\`, \`checkpoint.jsonl\`, \`prompt-attempt-$(attempt_label "$prior_attempt").md\`
- Recomputed on resumed attempt: \`events.jsonl\`, \`_stdout.md\`, \`stderr.txt\`, \`transcript.md\`
- Cost before resumption: $prior_cost USD
- Cost for resumed attempt only: $last_attempt_cost USD
- Cumulative cost after resumption: $total_cost USD
- Final status after resumed attempt: \`$status\`
EOF
}

build_cumulative_driver_result() {
  local run_dir="$1" driver_result_json="$2"
  local attempt_meta
  local -a archived_meta_files=()
  shopt -s nullglob
  for attempt_meta in "$run_dir"/attempts/attempt-*/meta.json; do
    archived_meta_files+=("$attempt_meta")
  done
  shopt -u nullglob

  if [[ ${#archived_meta_files[@]} -eq 0 ]]; then
    jq -cn --argjson current "$driver_result_json" '
      {
        completed_attempts: 1,
        cost: $current.cost,
        num_turns: $current.num_turns,
        duration_ms: $current.duration_ms,
        last_attempt_cost: $current.cost,
        last_attempt_num_turns: $current.num_turns,
        last_attempt_duration_ms: $current.duration_ms
      }
    '
    return
  fi

  jq -s --argjson current "$driver_result_json" '
    def sum_cost(field; current_value):
      ((map(.cost[field] // 0) | add) // 0) + (current_value // 0);
    def sum_scalar(field; current_value):
      ((map(.[field] // 0) | add) // 0) + (current_value // 0);
    def combined_notes(base; count):
      if count <= 1 then base
      elif (base // "") == "" then
        "Cumulative across " + (count | tostring) + " attempts; per-attempt artifacts are preserved under attempts/."
      else
        base + " Cumulative across " + (count | tostring) + " attempts; per-attempt artifacts are preserved under attempts/."
      end;
    . as $archived
    | (($archived | length) + 1) as $attempt_count
    | ($current.cost.pricing // {}) as $pricing
    | {
        completed_attempts: $attempt_count,
        cost: {
          input_tokens: sum_cost("input_tokens"; $current.cost.input_tokens),
          output_tokens: sum_cost("output_tokens"; $current.cost.output_tokens),
          cache_read_tokens: sum_cost("cache_read_tokens"; $current.cost.cache_read_tokens),
          cache_write_tokens: sum_cost("cache_write_tokens"; $current.cost.cache_write_tokens),
          actual_usd: sum_cost("actual_usd"; $current.cost.actual_usd),
          estimated_usd: sum_cost("estimated_usd"; $current.cost.estimated_usd),
          pricing: ($pricing + {notes: combined_notes($pricing.notes; $attempt_count)})
        },
        num_turns: sum_scalar("num_turns"; $current.num_turns),
        duration_ms: sum_scalar("duration_ms"; $current.duration_ms),
        last_attempt_cost: $current.cost,
        last_attempt_num_turns: $current.num_turns,
        last_attempt_duration_ms: $current.duration_ms
      }
  ' "${archived_meta_files[@]}"
}

# ── agent invocation ──────────────────────────────────────────────────────────
#
# invoke_agent <run_dir> <prompt>
#   Starts claude with stream-json output, writes events.jsonl + _stdout.md + stderr.txt
#   Runs a no-event watchdog in background (default 300s — catches multi-minute hangs
#   without firing on legitimate silence during nested subprocess calls like ./personalagentkit plant).
#   Sets global AGENT_STATUS to: success | failure | killed
#
invoke_agent() {
  local run_dir="$1"
  local prompt="$2"
  local idle_timeout="${PAK_IDLE_TIMEOUT:-600}"
  local run_id
  run_id=$(basename "$run_dir")
  DRIVER_RESULT_JSON=$(
    cd "$REPO_ROOT" && printf "%s" "$prompt" | \
      PAK_ACTIVE_RUN_ID="$run_id" \
      PAK_ACTIVE_RUN_DIR="$run_dir" \
      PAK_ACTIVE_DRIVER="$PAK_DRIVER" \
      python3 -m runner.host invoke \
        --driver "$PAK_DRIVER" \
        --model "$_driver_model" \
        --run-dir "$run_dir" \
        --idle-timeout "$idle_timeout"
  ) || die "driver invocation failed"
  AGENT_STATUS=$(echo "$DRIVER_RESULT_JSON" | jq -r '.status')
}

persist_driver_result_to_meta() {
  local meta="$1"
  local run_dir="$2"
  local driver_result_json="$3"
  local completed_at
  completed_at=$(jq -r '.completed_at // empty' "$meta" 2>/dev/null)
  [[ -n "$completed_at" ]] || completed_at=$(iso_now)

  local cumulative_json
  cumulative_json=$(build_cumulative_driver_result "$run_dir" "$driver_result_json")

  local outputs='[]'
  [[ -f "$run_dir/reflection.md" ]] && outputs='["reflection.md"]'
  jq \
    --arg completed     "$completed_at" \
    --argjson driver_result "$driver_result_json" \
    --argjson cumulative "$cumulative_json" \
    --argjson outputs   "$outputs" \
    '.completed_at = (if (.completed_at | type) == "string" and .completed_at != "" then .completed_at else $completed end)
   | .status      = $driver_result.status
   | .cost        = $cumulative.cost
   | .num_turns   = $cumulative.num_turns
   | .duration_ms = $cumulative.duration_ms
   | .completed_attempts = $cumulative.completed_attempts
   | .last_attempt_cost = $cumulative.last_attempt_cost
   | .last_attempt_num_turns = $cumulative.last_attempt_num_turns
   | .last_attempt_duration_ms = $cumulative.last_attempt_duration_ms
   | .outputs     = $outputs
   | del(.zombie_cleaned_at, .zombie_note)' \
    "$meta" > "$meta.tmp" && mv "$meta.tmp" "$meta"
}

# ── subcommands ───────────────────────────────────────────────────────────────

cmd_run() {
  local goal_file="" explicit_driver="" explicit_model=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --driver) [[ -n "${2:-}" ]] || die "--driver requires a value"; explicit_driver="$2"; shift 2 ;;
      --model)  [[ -n "${2:-}" ]] || die "--model requires a value"; explicit_model="$2"; shift 2 ;;
      --*)      die "unknown flag: $1" ;;
      *)
        [[ -z "$goal_file" ]] || die "usage: personalagentkit run [--driver <name>] [--model <name>] <goal-file>"
        goal_file="$1"
        shift
        ;;
    esac
  done
  [[ -n "$goal_file" ]] || die "usage: personalagentkit run [--driver <name>] [--model <name>] <goal-file>"
  [[ -f "$REPO_ROOT/$goal_file" ]] || die "goal file not found: $goal_file"

  if [[ "${PAK_ALLOW_NESTED_RUN:-0}" != "1" ]] && \
     [[ -n "${PAK_ACTIVE_RUN_ID:-}" || -n "${PAK_ACTIVE_RUN_DIR:-}" || -n "${PAK_ACTIVE_DRIVER:-}" ]]; then
    die "$(cat <<EOF
nested personalagentkit run is blocked inside an active run

Active run: ${PAK_ACTIVE_RUN_ID:-unknown} (${PAK_ACTIVE_DRIVER:-unknown driver})
Active run dir: ${PAK_ACTIVE_RUN_DIR:-unknown}
Requested goal: $goal_file

Route cross-driver work through goal frontmatter such as \`driver: claude\` and let normal dispatch launch the run.
Do not call \`./scripts/personalagentkit run ...\` from inside another run.
If a run needs more work, submit or write a goal instead.

For debugging only, set PAK_ALLOW_NESTED_RUN=1 to bypass this guard explicitly.
EOF
)"
  fi

  resolve_goal_routing "$REPO_ROOT/$goal_file" "$explicit_driver" "$explicit_model"
  require python3
  require "$_driver_bin"
  require jq

  local goal_id
  goal_id=$(goal_id_from_file "$goal_file")

  local assigned_to
  assigned_to=$(parse_goal_meta "$REPO_ROOT/$goal_file" assigned_to)

  local base_dir run_dir
  if [[ -n "$assigned_to" ]]; then
    base_dir="$REPO_ROOT/plants/$assigned_to"
    mkdir -p "$base_dir/goals" "$base_dir/runs" "$base_dir/memory"
    [[ -f "$base_dir/MOTIVATION.md" ]] || cp "$REPO_ROOT/MOTIVATION.md" "$base_dir/MOTIVATION.md" 2>/dev/null || true
    run_dir="$base_dir/runs/$goal_id"
  else
    base_dir="$REPO_ROOT"
    run_dir="$REPO_ROOT/runs/$goal_id"
  fi
  mkdir -p "$run_dir"

  local meta="$run_dir/meta.json"
  local started_at
  started_at=$(iso_now)

  local goal_type requires_reflection
  goal_type=$(classify_goal_type "$goal_id")
  requires_reflection=$(goal_type_requires_reflection "$goal_type")

  # ── write initial run record (P5: record before agent acts) ──────────────
  local submitted_by="${TELOS_SUBMITTED_BY:-}"
  jq -n \
    --arg run_id       "$goal_id" \
    --arg goal_file    "$goal_file" \
    --arg started      "$started_at" \
    --arg driver       "$PAK_DRIVER" \
    --arg model        "$_driver_model" \
    --arg agent        "${_driver_model:-$PAK_DRIVER}" \
    --arg submitted_by "$submitted_by" \
    --arg goal_type    "$goal_type" \
    --argjson requires_reflection "$requires_reflection" \
    '{
      run_id:     $run_id,
      goal_file:  $goal_file,
      started_at: $started,
      completed_at: null,
      status:     "running",
      driver:     $driver,
      model:      $model,
      agent:      $agent,
      goal_type:  $goal_type,
      requires_reflection: $requires_reflection,
      cost:       null,
      outputs:    [],
      notes:      null
    } | if $submitted_by != "" then . + {submitted_by: $submitted_by} else . end' > "$meta"

  write_goal_run_pointer "$goal_file"
  write_run_readme "$run_dir"

  echo "personalagentkit: run $goal_id started at $started_at"
  echo "personalagentkit: record → $meta"

  # ── build the prompt and write prompt artifact ────────────────────────────
  local attempt prompt
  attempt=$(next_attempt_number "$run_dir")
  prompt=$(build_run_prompt "$goal_file" "$base_dir" "$goal_type" "$requires_reflection")
  write_prompt_artifact "$run_dir" "$attempt" "$prompt"
  append_checkpoint "$run_dir" "started" "goal=$goal_file driver=$PAK_DRIVER model=$_driver_model"

  # ── invoke agent, stream events to events.jsonl ───────────────────────────
  invoke_agent "$run_dir" "$prompt"
  local driver_result_json="$DRIVER_RESULT_JSON"
  local status="$AGENT_STATUS"

  persist_driver_result_to_meta "$meta" "$run_dir" "$driver_result_json"
  write_run_transcript "$run_dir"
  write_goal_run_pointer "$goal_file"
  write_run_readme "$run_dir"
  local completed_at
  completed_at=$(jq -r '.completed_at // empty' "$meta" 2>/dev/null)

  # ── validate meta.json (P2: schema is a contract, not documentation) ──────
  local validation_errors
  validation_errors=$(jq -r '
    [
      (if (.run_id       | type) != "string"  then "run_id: missing or not a string"         else empty end),
      (if (.goal_file    | type) != "string"  then "goal_file: missing or not a string"       else empty end),
      (if (.started_at   | type) != "string"  then "started_at: missing or not a string"      else empty end),
      (if (.status       | type) != "string"  then "status: missing or not a string"          else empty end),
      (if (.completed_at | type) != "string"  then "completed_at: missing or not a string"    else empty end),
      (if (.status == "killed") then empty elif (.num_turns   | type) != "number" then "num_turns: missing or not an integer"   else empty end),
      (if (.status == "killed") then empty elif (.duration_ms | type) != "number" then "duration_ms: missing or not an integer" else empty end),
      (if ((.cost | type) != "object") then "cost: missing or not an object"
       elif (((.cost.actual_usd | type) == "number") or ((.cost.estimated_usd | type) == "number")) then empty
       elif (.cost.pricing.notes | type) == "string" then empty
       else "cost: requires actual_usd, estimated_usd, or pricing.notes explaining why neither is available" end),
      (if ((.cost.estimated_usd | type) == "number") and ((.cost.pricing.source // "") != "local-estimate") then "cost.pricing.source: estimated cost requires local-estimate" else empty end),
      (if ((.cost.estimated_usd | type) == "number") and ((.cost.pricing.version | type) != "string") then "cost.pricing.version: estimated cost requires a pricing version" else empty end),
      (if ((.cost.estimated_usd | type) == "number") and ((.cost.pricing.retrieved_at | type) != "string") then "cost.pricing.retrieved_at: estimated cost requires retrieved_at" else empty end)
    ] | .[]
  ' "$meta" 2>/dev/null || true)

  if [[ -n "$validation_errors" ]]; then
    echo "personalagentkit: WARNING: meta.json validation failed for $goal_id:" >&2
    while IFS= read -r line; do
      echo "  - $line" >&2
    done <<< "$validation_errors"
  fi

  if [[ "$requires_reflection" == "true" && ! -f "$run_dir/reflection.md" ]]; then
    echo "personalagentkit: WARNING: reflection.md missing from $run_dir" >&2
  fi

  echo "personalagentkit: run $goal_id completed ($status) at $completed_at"
  echo "personalagentkit: cost = $(preferred_cost_from_meta "$meta") USD"
  echo "personalagentkit: response → $run_dir/_stdout.md"

  # ── auto-commit run directory (P8: git history is the system's memory) ────
  (
    flock -x 200
    git -C "$REPO_ROOT" add "$run_dir" "$REPO_ROOT/$goal_file" 2>/dev/null
    git -C "$REPO_ROOT" add -A 2>/dev/null
    if git -C "$REPO_ROOT" commit -m "run $goal_id: finalize" 2>/dev/null; then
      echo "personalagentkit: committed run $goal_id"
    else
      echo "personalagentkit: WARNING: auto-commit failed for $goal_id" >&2
    fi
  ) 200>"$REPO_ROOT/.personalagentkit-git.lock"
}

cmd_status() {
  local runs_dir="$REPO_ROOT/runs"
  local now_epoch
  now_epoch=$(date +%s)

  python3 -m runner.reconcile --root "$REPO_ROOT" >/dev/null 2>&1 || true

  # ── in-flight runs (root + all plants) shown first ─────────────────────────
  local running_found=false
  local meta
  for meta in \
      "$runs_dir"/*/meta.json \
      "$REPO_ROOT/plants"/*/runs/*/meta.json; do
    [[ -f "$meta" ]] || continue
    local status_raw
    status_raw=$(jq -r '.status // ""' "$meta" 2>/dev/null)
    [[ "$status_raw" == "running" ]] || continue

    if [[ "$running_found" == "false" ]]; then
      printf "  RUNNING\n"
      running_found=true
    fi

    local run_id started_at
    run_id=$(jq -r '.run_id // ""' "$meta" 2>/dev/null)
    started_at=$(jq -r '.started_at // ""' "$meta" 2>/dev/null)

    local started_epoch elapsed em es
    started_epoch=$(iso_to_epoch "$started_at")
    elapsed=$(( now_epoch - started_epoch ))
    em=$(( elapsed / 60 ))
    es=$(( elapsed % 60 ))

    local events_file event_count
    events_file="$(dirname "$meta")/events.jsonl"
    event_count=0
    [[ -f "$events_file" ]] && event_count=$(wc -l < "$events_file" 2>/dev/null | tr -d ' ' || echo 0)

    local display_id
    if [[ "$meta" == *"/plants/"* ]]; then
      local plant_name
      plant_name=$(echo "$meta" | sed 's|.*/plants/\([^/]*\)/.*|\1|')
      display_id="${plant_name}/${run_id}"
    else
      display_id="$run_id"
    fi

    printf "  %-40s  %dm %02ds   %s events\n" "$display_id" "$em" "$es" "$event_count"
  done
  [[ "$running_found" == "true" ]] && printf "\n"

  # ── completed runs table (root + all plant runs, sorted by NNN) ────────────
  printf "%-36s  %-10s  %-10s  %-6s  %s\n" "RUN" "STATUS" "COST" "TURNS" "DURATION"

  # collect all meta.json paths from root runs/ and all plant runs/
  local all_metas=()
  for meta in "$runs_dir"/*/meta.json \
              "$REPO_ROOT/plants"/*/runs/*/meta.json; do
    [[ -f "$meta" ]] || continue
    all_metas+=("$meta")
  done

  # sort by run directory name (NNN-slug sorts correctly lexicographically)
  local sorted_metas
  IFS=$'\n' sorted_metas=($(printf '%s\n' "${all_metas[@]}" | sort -t/ -k1,1 || true))
  unset IFS

  for meta in "${sorted_metas[@]:-}"; do
    [[ -f "$meta" ]] || continue
    local run_id cost_raw turns dur_ms status_raw started_at
    run_id=$(jq -r '.run_id // ""' "$meta" 2>/dev/null)
    cost_raw=$(jq -r '.cost.actual_usd // .cost.estimated_usd // "null"' "$meta" 2>/dev/null)
    turns=$(jq -r '.num_turns // "null"' "$meta" 2>/dev/null)
    dur_ms=$(jq -r '.duration_ms // "null"' "$meta" 2>/dev/null)
    status_raw=$(jq -r '.status // "null"' "$meta" 2>/dev/null)
    [[ "$status_raw" != "null" ]] && status_raw=$(normalize_status "$status_raw")
    started_at=$(jq -r '.started_at // "null"' "$meta" 2>/dev/null)

    # prefix plant runs with plant name for clarity
    local display_id="$run_id"
    if [[ "$meta" == *"/plants/"* ]]; then
      local plant_name
      plant_name=$(echo "$meta" | sed 's|.*/plants/\([^/]*\)/.*|\1|')
      display_id="${plant_name}/${run_id}"
    fi

    if [[ "$cost_raw" == "null" ]]; then
      cost_fmt="-"
    else
      cost_fmt=$(printf '$%.4f' "$cost_raw")
    fi

    if [[ "$turns" == "null" ]]; then
      turns_fmt="-"
    else
      turns_fmt="$turns"
    fi

    if [[ "$dur_ms" == "null" ]]; then
      dur_fmt="-"
    else
      dur_s=$(( dur_ms / 1000 ))
      dur_fmt="${dur_s}s"
    fi

    local status_fmt
    if [[ "$status_raw" == "running" && "$started_at" != "null" ]]; then
      local started_epoch elapsed
      started_epoch=$(iso_to_epoch "$started_at")
      elapsed=$(( now_epoch - started_epoch ))
      if (( elapsed > 7200 )); then
        status_fmt="stale"
      else
        status_fmt="running"
      fi
    elif [[ "$status_raw" == "null" ]]; then
      status_fmt="-"
    else
      status_fmt="$status_raw"
    fi

    printf "%-36s  %-10s  %-10s  %-6s  %s\n" "$display_id" "$status_fmt" "$cost_fmt" "$turns_fmt" "$dur_fmt"
  done

  printf "\n%s\n" "$(legacy_status_summary)"
  printf "\n"
  surface_pending_operator_mail "personalagentkit"

  printf "\nHEALTH\n"
  (
    cd "$REPO_ROOT"
    python3 - "$REPO_ROOT" <<'PY'
import sys
from pathlib import Path

from runner.health import get_health_issues
from runner.reflection import reflection_policy_summary

repo_root = Path(sys.argv[1])
missing, stale, active, pending = get_health_issues(repo_root, stale_threshold_secs=7200)

print(f"  {reflection_policy_summary()}")
if not missing and not stale and not active and not pending:
    print("  all clear")
else:
    for item in stale:
        print(f"  {item}  stale")
    for item in active:
        print(f"  {item}  running")
    for item in missing:
        print(f"  {item}  missing reflection")
    for plant, count in pending.items():
        print(f"  {plant}  {count} pending goals")
PY
  )
}

cmd_plant() {
  local seed_name="${1:-}"
  local plant_name="${2:-}"
  [[ -n "$seed_name" ]]  || die "usage: personalagentkit plant <seed-name> <plant-name>"
  [[ -n "$plant_name" ]] || die "usage: personalagentkit plant <seed-name> <plant-name>"

  resolve_driver_config "$PAK_DEFAULT_DRIVER" "$PAK_DEFAULT_MODEL"
  require python3
  require "$_driver_bin"
  require jq

  local seed_file="$REPO_ROOT/seeds/${seed_name}.md"
  [[ -f "$seed_file" ]] || die "seed not found: seeds/${seed_name}.md"

  local plant_dir="$REPO_ROOT/plants/$plant_name"
  [[ ! -d "$plant_dir" ]] || die "plant already exists: $plant_dir"

  # ── scaffold the plant ──────────────────────────────────────────────────
  mkdir -p "$plant_dir/goals" "$plant_dir/runs/000-genesis" "$plant_dir/memory"

  cp "$REPO_ROOT/MOTIVATION.md" "$plant_dir/MOTIVATION.md"
  cp "$seed_file" "$plant_dir/goals/000-genesis.md"
  echo "$seed_name" > "$plant_dir/seed"

  local run_dir="$plant_dir/runs/000-genesis"
  local meta="$run_dir/meta.json"
  local started_at
  started_at=$(iso_now)

  local goal_type="genesis"
  local requires_reflection="false"

  echo "personalagentkit: planting $plant_name from seed $seed_name"
  echo "personalagentkit: plant dir → $plant_dir"

  # ── write initial run record ─────────────────────────────────────────────
  local genesis_goal_file="plants/$plant_name/goals/000-genesis.md"
  jq -n \
    --arg run_id    "000-genesis" \
    --arg goal_file "$genesis_goal_file" \
    --arg started   "$started_at" \
    --arg driver    "$PAK_DRIVER" \
    --arg model     "$_driver_model" \
    --arg agent     "${_driver_model:-$PAK_DRIVER}" \
    --arg goal_type "$goal_type" \
    --argjson requires_reflection "$requires_reflection" \
    '{
      run_id:     $run_id,
      goal_file:  $goal_file,
      started_at: $started,
      completed_at: null,
      status:     "running",
      driver:     $driver,
      model:      $model,
      agent:      $agent,
      goal_type:  $goal_type,
      requires_reflection: $requires_reflection,
      cost:       null,
      outputs:    [],
      notes:      null
    }' > "$meta"

  write_goal_run_pointer "$genesis_goal_file"
  write_run_readme "$run_dir"

  # ── build the prompt and write prompt artifact ────────────────────────────
  local attempt prompt
  attempt=$(next_attempt_number "$run_dir")
  prompt=$(build_run_prompt "$genesis_goal_file" "$plant_dir" "$goal_type" "$requires_reflection")
  write_prompt_artifact "$run_dir" "$attempt" "$prompt"
  append_checkpoint "$run_dir" "started" "goal=$genesis_goal_file driver=$PAK_DRIVER model=$_driver_model"

  # ── invoke agent, stream events to events.jsonl ───────────────────────────
  invoke_agent "$run_dir" "$prompt"
  local driver_result_json="$DRIVER_RESULT_JSON"
  local status="$AGENT_STATUS"

  persist_driver_result_to_meta "$meta" "$run_dir" "$driver_result_json"
  write_run_transcript "$run_dir"
  write_goal_run_pointer "$genesis_goal_file"
  write_run_readme "$run_dir"
  local completed_at
  completed_at=$(jq -r '.completed_at // empty' "$meta" 2>/dev/null)

  if [[ "$requires_reflection" == "true" && ! -f "$run_dir/reflection.md" ]]; then
    echo "personalagentkit: WARNING: reflection.md missing from $run_dir" >&2
  fi

  echo "personalagentkit: genesis run completed ($status) at $completed_at"
  echo "personalagentkit: cost = $(preferred_cost_from_meta "$meta") USD"
  echo "personalagentkit: plant $plant_name is alive → $plant_dir"

  # ── auto-commit run directory (P8: git history is the system's memory) ────
  git -C "$REPO_ROOT" add "$run_dir" "$plant_dir/goals/000-genesis.md" 2>/dev/null
  git -C "$REPO_ROOT" add -A 2>/dev/null
  if git -C "$REPO_ROOT" commit -m "run 000-genesis: finalize" 2>/dev/null; then
    echo "personalagentkit: committed run 000-genesis"
  else
    echo "personalagentkit: WARNING: auto-commit failed for 000-genesis" >&2
  fi
}

cmd_plant_run() {
  # Deprecated: plant routing is now handled via assigned_to: frontmatter in the goal file.
  # This shim strips the plant-name argument and delegates to cmd_run.
  local plant_name="" goal_rel="" passthrough=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --driver|--model) passthrough+=("$1" "${2:-}"); shift 2 ;;
      --*)      die "unknown flag: $1" ;;
      *)        if [[ -z "$plant_name" ]]; then
          plant_name="$1"
        elif [[ -z "$goal_rel" ]]; then
          goal_rel="$1"
        else
          die "usage: personalagentkit plant-run [--driver <name>] [--model <name>] <plant-name> <goal-file>"
        fi
        shift ;;
    esac
  done
  [[ -n "$plant_name" ]] || die "usage: personalagentkit plant-run <plant-name> <goal-file>"
  [[ -n "$goal_rel" ]]   || die "usage: personalagentkit plant-run <plant-name> <goal-file>"
  cmd_run "${passthrough[@]}" "$goal_rel"
}

cmd_garden() {
  local plants_dir="$REPO_ROOT/plants"
  if [[ ! -d "$plants_dir" ]] || [[ -z "$(ls -A "$plants_dir" 2>/dev/null)" ]]; then
    echo "garden is empty — plant a seed with: personalagentkit plant <seed> <name>"
    return
  fi

  printf "%-20s  %-16s  %-10s  %-10s  %-6s  %s\n" "PLANT" "LATEST RUN" "STATUS" "COST" "TURNS" "DURATION"
  for plant_path in "$plants_dir"/*/; do
    [[ -d "$plant_path" ]] || continue
    local plant_name
    plant_name=$(basename "$plant_path")

    local runs_dir="$plant_path/runs"
    if [[ ! -d "$runs_dir" ]] || [[ -z "$(ls -A "$runs_dir" 2>/dev/null)" ]]; then
      printf "%-20s  %-16s  %-10s  %-10s  %-6s  %s\n" "$plant_name" "(no runs)" "-" "-" "-" "-"
      continue
    fi

    # find the latest run by directory name (lexicographic, NNN-slug sorts correctly)
    local latest_run_dir
    latest_run_dir=$(ls -d "$runs_dir"/*/ 2>/dev/null | sort | tail -1)
    local latest_run_name
    latest_run_name=$(basename "$latest_run_dir")
    local meta="$latest_run_dir/meta.json"

    local cost_fmt turns_fmt dur_fmt status_fmt
    if [[ -f "$meta" ]]; then
      local cost_raw turns dur_ms status_raw
      cost_raw=$(jq -r '.cost.actual_usd // .cost.estimated_usd // "null"' "$meta" 2>/dev/null)
      turns=$(jq -r '.num_turns // "null"' "$meta" 2>/dev/null)
      dur_ms=$(jq -r '.duration_ms // "null"' "$meta" 2>/dev/null)
      status_raw=$(jq -r '.status // "null"' "$meta" 2>/dev/null)
      [[ "$status_raw" != "null" ]] && status_raw=$(normalize_status "$status_raw")

      cost_fmt=$(   [[ "$cost_raw"   == "null" ]] && echo "-" || printf '$%.4f' "$cost_raw")
      turns_fmt=$(  [[ "$turns"      == "null" ]] && echo "-" || echo "$turns")
      dur_fmt=$(    [[ "$dur_ms"     == "null" ]] && echo "-" || echo "$(( dur_ms / 1000 ))s")
      status_fmt=$( [[ "$status_raw" == "null" ]] && echo "-" || echo "$status_raw")
    else
      cost_fmt="-"; turns_fmt="-"; dur_fmt="-"; status_fmt="-"
    fi

    printf "%-20s  %-16s  %-10s  %-10s  %-6s  %s\n" "$plant_name" "$latest_run_name" "$status_fmt" "$cost_fmt" "$turns_fmt" "$dur_fmt"
  done
}

cmd_tend() {
  local trigger="unspecified"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --trigger) trigger="$2"; shift 2 ;;
      *) break ;;
    esac
  done

  local gardener="gardener"
  local plant_dir="$REPO_ROOT/plants/$gardener"
  [[ -d "$plant_dir" ]] || die "gardener plant not found: plants/$gardener"

  local goals_dir="$REPO_ROOT/goals"
  mkdir -p "$goals_dir"

  # auto-increment: find highest NNN across root goals/, root runs/, and all plant runs/
  local max_n=0
  for f in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md \
            "$REPO_ROOT/runs"/[0-9][0-9][0-9]-*/; do
    [[ -e "$f" ]] || continue
    local nnn
    nnn=$(basename "${f%.md}" | grep -oE '^[0-9]+' | head -1)
    [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
  done
  for plant_path in "$REPO_ROOT/plants"/*/; do
    for f in "${plant_path}runs"/[0-9][0-9][0-9]-*/; do
      [[ -d "$f" ]] || continue
      local nnn
      nnn=$(basename "$f" | grep -oE '^[0-9]+' | head -1)
      [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
    done
  done
  local goal_num
  goal_num=$(printf "%03d" $(( max_n + 1 )))
  local goal_file="goals/${goal_num}-tend.md"
  local goal_path="$goals_dir/${goal_num}-tend.md"

  cat > "$goal_path" <<TEND
---
assigned_to: gardener
trigger: $trigger
---
TEND
  cat >> "$goal_path" <<'TEND'
# Tend the Garden

## Read state

Note the trigger from frontmatter (`trigger:` field) — include it in your summary output.

Run these from the personalagentkit root:
- `./scripts/personalagentkit status` — all runs, costs, turns, duration
- `python3 scripts/report` — cost trends and summary stats
- `ls inbox/` — any messages waiting for reply?

For each plant:
- Read `plants/<name>/memory/MEMORY.md`
- Read its most recent run's `meta.json`, `reflection.md`
- Check for `plants/<name>/capability-gap-*.md` — named gap files identify
  specific missing capabilities (e.g., `capability-gap-sms-receipt.md`).
  Commission gap-closing goals as needed. Goals that `requires:` a gapped
  capability are blocked by the dispatcher automatically; other goals for
  that plant run normally.

For root:
- `ls runs/*/reflection.md` — any runs missing reflections?
- Check `horizons/*.md` — open horizons with no active work?
- Check `memory/MEMORY.md` — stale entries that have been resolved?

## Decide

For each plant: stuck, drifting, progressing, or ready for next challenge?
For root: is there an infrastructure gap limiting the system?

**Loop detection (required):** Read the plant's last 5 runs. If the same goal
type has run 3+ consecutive times with no meaningful outcome change, the plant
is looping. Commission a different type or leave it alone. Catch this yourself
through judgment — don't rely on a mechanical counter.

**Spike before build (required):** Before commissioning a `build` goal for a
new capability, first consider whether an explorer `spike` would improve the
implementation. Skip the spike only when the capability is well-understood.

## Write (or don't)

Restraint is a quality. Write a goal only when intervention is warranted.
A plant making genuine progress should be left alone.

When a genuine gap exists, write a goal file at `goals/NNN-slug.md` or use
`./scripts/personalagentkit submit`. All goals live in root `goals/` — never in plant-specific
directories.

**Goal routing:**
- Use `assigned_to: <plant-name>` frontmatter to route to a plant
- Use `depends_on: [prior-slug]` to enforce ordering
- Use `priority: N` (1=urgent, 10=someday, default 5) to control dispatch order
- Never write a goal whose only purpose is to forward another goal — that is a
  routing bug (you forgot to use frontmatter)

**Reviewer commissioning rule:** Only write reviewer goals for `build`, `fix`,
or `spike` type runs. Never for `integrate-reviewer-feedback` runs — reviewing
reflections about reflections creates a closed loop that produces no value.

## Produce outputs

Every tend run:
1. Write `reflection.md` to the run directory — what did tending reveal?
2. Update `memory/MEMORY.md` if this tend revealed durable insights
3. Your final message is your summary to the operator — include what you tended and what to watch

Do NOT make a terminal commit — the runner's auto-commit captures everything.
TEND

  write_goal_run_pointer "$goal_file"
  echo "personalagentkit: wrote tend goal → $goal_path"
  cmd_plant_run "$gardener" "$goal_file"
}

cmd_retrospective() {
  local gardener="gardener"
  local plant_dir="$REPO_ROOT/plants/$gardener"
  [[ -d "$plant_dir" ]] || die "gardener plant not found: plants/$gardener"

  # Ensure shared knowledge directory exists
  local shared_knowledge
  shared_knowledge="$(dirname "$REPO_ROOT")/shared/knowledge"
  mkdir -p "$shared_knowledge"

  local goals_dir="$REPO_ROOT/goals"
  mkdir -p "$goals_dir"

  # auto-increment: find highest NNN across root goals/, root runs/, and all plant runs/
  local max_n=0
  for f in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md \
            "$REPO_ROOT/runs"/[0-9][0-9][0-9]-*/; do
    [[ -e "$f" ]] || continue
    local nnn
    nnn=$(basename "${f%.md}" | grep -oE '^[0-9]+' | head -1)
    [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
  done
  for plant_path in "$REPO_ROOT/plants"/*/; do
    for f in "${plant_path}runs"/[0-9][0-9][0-9]-*/; do
      [[ -d "$f" ]] || continue
      local nnn
      nnn=$(basename "$f" | grep -oE '^[0-9]+' | head -1)
      [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
    done
  done
  local goal_num
  goal_num=$(printf "%03d" $(( max_n + 1 )))
  local goal_file="goals/${goal_num}-retrospective.md"
  local goal_path="$goals_dir/${goal_num}-retrospective.md"

  cat > "$goal_path" <<'RETRO'
---
assigned_to: gardener
---
# Retrospective

## What

Synthesize patterns across recent runs. This is NOT a tend — do not write goals
or update memory. Focus on observation, analysis, and shared knowledge.

## How

1. Run `./scripts/personalagentkit status` for full run history.
2. Identify your window: find the last retrospective run (if any) and read everything since.
3. Read ALL reflections from runs in your window — not just the latest per plant.
   Read each plant's `memory/MEMORY.md` for context.
4. Read existing files in `../shared/knowledge/` (if any).
5. Analyze for:
   - **Prediction errors / surprises** — outcomes that diverged from expectations
   - **Patterns across runs** — recurring failure modes, successful strategies
   - **Cost trends** — are costs rising, falling, stable? Which plants cost most?
   - **Strategy assessment** — is the current approach working?
   - **Stale state** — memory entries, capability gaps, or shared knowledge that are outdated
6. Write shared knowledge: at most 1–2 new fact files to `../shared/knowledge/`.
   Only write facts grounded in evidence from multiple runs. Format:
   ```
   # <fact title>
   **Observation:** <what was observed>
   **Evidence:** runs NNN, NNN; <brief description>
   **Confidence:** high | medium | low
   **Date:** YYYY-MM-DD
   ```
   Delete or update any stale facts already there.
7. Write `reflection.md` to the run directory.
8. Your final message is your synthesis to the operator, structured as:
   - **Surprises** — what was unexpected
   - **Patterns** — what keeps happening
   - **Strategy** — assessment of current direction
   - **Actions** — what the next tend should consider (but do NOT write goals)

## Constraints

- Do NOT write goals — that's what tends do
- Do NOT update plant memory or root memory — observe only
- Do NOT make a terminal commit — the runner's auto-commit captures everything
- Read broadly: the value of a retrospective is seeing what individual tends miss
RETRO

  # Patch the hardcoded knowledge path to match this installation
  sed -i "s|../shared/knowledge|${shared_knowledge}|g" "$goal_path"

  write_goal_run_pointer "$goal_file"
  echo "personalagentkit: wrote retrospective goal → $goal_path"
  cmd_plant_run "$gardener" "$goal_file"
}

cmd_regenesis() {
  local plant_name="${1:-}"
  [[ -n "$plant_name" ]] || die "usage: personalagentkit regenesis <plant-name> [seed-name]"

  local plant_dir="$REPO_ROOT/plants/$plant_name"
  [[ -d "$plant_dir" ]] || die "plant not found: plants/$plant_name"

  local seed_name="${2:-}"
  if [[ -z "$seed_name" ]]; then
    local seed_file="$plant_dir/seed"
    [[ -f "$seed_file" ]] || die "no seed file at $seed_file — pass seed name explicitly: personalagentkit regenesis $plant_name <seed-name>"
    seed_name=$(cat "$seed_file")
  fi

  local seed_path="$REPO_ROOT/seeds/${seed_name}.md"
  [[ -f "$seed_path" ]] || die "seed not found: seeds/${seed_name}.md"

  resolve_driver_config "$PAK_DEFAULT_DRIVER" "$PAK_DEFAULT_MODEL"
  require python3
  require "$_driver_bin"
  require jq

  local goals_dir="$REPO_ROOT/goals"
  mkdir -p "$goals_dir"

  # auto-increment: find highest NNN across root goals/, root runs/, and all plant runs/
  local max_n=0
  for f in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md \
            "$REPO_ROOT/runs"/[0-9][0-9][0-9]-*/; do
    [[ -e "$f" ]] || continue
    local nnn
    nnn=$(basename "${f%.md}" | grep -oE '^[0-9]+' | head -1)
    [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
  done
  for plant_path in "$REPO_ROOT/plants"/*/; do
    for f in "${plant_path}runs"/[0-9][0-9][0-9]-*/; do
      [[ -d "$f" ]] || continue
      local nnn
      nnn=$(basename "$f" | grep -oE '^[0-9]+' | head -1)
      [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
    done
  done
  local goal_num
  goal_num=$(printf "%03d" $(( max_n + 1 )))
  local goal_file="goals/${goal_num}-regenesis.md"
  local goal_path="$goals_dir/${goal_num}-regenesis.md"

  local seed_content
  seed_content=$(cat "$seed_path")

  cat > "$goal_path" <<REGENESIS
---
assigned_to: $plant_name
---
# Re-genesis

Your seed has been updated. Integrate the changes into your memory without
losing your accumulated knowledge or identity.
- Do NOT make a terminal commit — the runner's auto-commit captures everything
- Your final message is your summary to the operator — what changed and what carried over

## Current seed content

\`\`\`
$seed_content
\`\`\`
REGENESIS

  write_goal_run_pointer "$goal_file"
  echo "telos: wrote regenesis goal → $goal_path"
  cmd_plant_run "$plant_name" "$goal_file"
}

cmd_cycle() {
  local workers=2 tend_interval=300 max_cost="" retro_interval=14400 fg=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workers)        workers="$2";        shift 2 ;;
      --tend-interval)  tend_interval="$2";  shift 2 ;;
      --max-cost)       max_cost="$2";       shift 2 ;;
      --retro-interval) retro_interval="$2"; shift 2 ;;
      --fg)             fg=true;             shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  local script="$REPO_ROOT/scripts/dispatch.py"
  if [[ ! -f "$script" ]] || [[ ! -s "$script" ]]; then
    cmd_cycle_legacy "$@"
    return $?
  fi
  local args=(--workers "$workers" --tend-interval "$tend_interval" --retro-interval "$retro_interval")
  [[ -n "$max_cost" ]] && args+=(--max-cost "$max_cost")

  # Clear sentinels from any previous stop/pause
  rm -f "$REPO_ROOT/.personalagentkit-pause" "$REPO_ROOT/.personalagentkit-stop"

  # Save params so restart can reuse them
  local params_file="$REPO_ROOT/.personalagentkit-cycle-params"
  {
    echo "workers=$workers"
    echo "tend_interval=$tend_interval"
    echo "retro_interval=$retro_interval"
    echo "max_cost=$max_cost"
  } > "$params_file"

  # Clear stale pyc cache
  rm -f "$REPO_ROOT/scripts/__pycache__/dispatch."*.pyc 2>/dev/null

  # Auto-launch in tmux unless --fg, already in tmux, or tmux unavailable
  local garden_name
  garden_name=$(basename "$REPO_ROOT")
  local session="telos-${garden_name}"

  if [[ "$fg" == "false" ]] && [[ -z "${TMUX:-}" ]] && command -v tmux &>/dev/null; then
    # Build the full command to run inside tmux
    local cmd="cd $(printf '%q' "$REPO_ROOT") && $(printf '%q' "$REPO_ROOT/scripts/personalagentkit") cycle --fg"
    cmd+=" --workers $workers --tend-interval $tend_interval --retro-interval $retro_interval"
    [[ -n "$max_cost" ]] && cmd+=" --max-cost $max_cost"

    # Kill existing session if present (stale from previous run)
    tmux kill-session -t "$session" 2>/dev/null || true
    tmux new-session -d -s "$session" "$cmd"
    echo "telos: cycle running in tmux session '$session'"
    echo "telos: attach with: tmux attach -t $session"
    echo "telos: stop with:   ./scripts/personalagentkit stop"
    return 0
  fi

  exec python3 "$script" --repo-root "$REPO_ROOT" "${args[@]}"
}

cmd_restart() {
  local params_file="$REPO_ROOT/.personalagentkit-cycle-params"
  [[ -f "$params_file" ]] || die "no previous cycle params found — run 'personalagentkit cycle' first"

  # Load saved params
  local workers=2 tend_interval=300 retro_interval=14400 max_cost=""
  while IFS='=' read -r key val; do
    case "$key" in
      workers)        workers="$val" ;;
      tend_interval)  tend_interval="$val" ;;
      retro_interval) retro_interval="$val" ;;
      max_cost)       max_cost="$val" ;;
    esac
  done < "$params_file"

  local garden_name
  garden_name=$(basename "$REPO_ROOT")
  local session="telos-${garden_name}"

  # Signal stop — dispatcher will finish in-flight goals then exit
  echo "telos: signaling stop..."
  touch "$REPO_ROOT/.personalagentkit-stop"

  # Wait for the dispatch.py process to exit (however long it takes)
  if command -v tmux &>/dev/null && tmux has-session -t "$session" 2>/dev/null; then
    echo "telos: waiting for dispatcher to finish in-flight goals..."
    # Find the dispatch.py pid inside the tmux pane and wait for it
    local dispatch_pid
    dispatch_pid=$(tmux list-panes -t "$session" -F '#{pane_pid}' 2>/dev/null | head -1)
    if [[ -n "$dispatch_pid" ]]; then
      # The tmux pane runs bash, which runs python3 dispatch.py — find the python child
      local py_pid
      py_pid=$(pgrep -P "$dispatch_pid" -f 'dispatch.py' 2>/dev/null || true)
      if [[ -n "$py_pid" ]]; then
        # Wait for the python process to exit naturally
        while kill -0 "$py_pid" 2>/dev/null; do
          sleep 2
        done
      else
        # Can't find python pid — fall back to waiting for pane to go dead
        while tmux list-panes -t "$session" -F '#{pane_dead}' 2>/dev/null | grep -q '^0$'; do
          sleep 2
        done
      fi
    fi

    # Reuse the tmux session — send the new cycle command into it
    local cmd="cd $(printf '%q' "$REPO_ROOT") && $(printf '%q' "$REPO_ROOT/scripts/personalagentkit") cycle --fg"
    cmd+=" --workers $workers --tend-interval $tend_interval --retro-interval $retro_interval"
    [[ -n "$max_cost" ]] && cmd+=" --max-cost $max_cost"

    tmux respawn-pane -k -t "$session" "$cmd"
    echo "telos: restarted in tmux session '$session'"
    echo "telos: attach with: tmux attach -t $session"
  else
    # No tmux session — just start a new cycle
    echo "telos: restarting cycle..."
    local cycle_args=(--workers "$workers" --tend-interval "$tend_interval" --retro-interval "$retro_interval")
    [[ -n "$max_cost" ]] && cycle_args+=(--max-cost "$max_cost")
    cmd_cycle "${cycle_args[@]}"
  fi
}

cmd_cycle_legacy() {
  local max_iter=5
  local max_cost=""
  local tend_every=4

  # parse flags and positional args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-cost)
        [[ -n "${2:-}" ]] || die "--max-cost requires a value"
        max_cost="$2"
        shift 2
        ;;
      --tend-every)
        [[ -n "${2:-}" ]] || die "--tend-every requires a value"
        tend_every="$2"
        shift 2
        ;;
      --*)
        die "unknown flag: $1"
        ;;
      *)
        max_iter="$1"
        shift
        ;;
    esac
  done

  local iter=0
  local cycle_cost=0
  local consecutive_type_count=0
  local last_goal_type=""

  local cost_msg=""
  [[ -n "$max_cost" ]] && cost_msg=", max_cost=\$$max_cost"
  echo "telos: cycle starting (max_iterations=$max_iter, tend_every=$tend_every$cost_msg)"

  # surface any pending inbox messages before the cycle begins
  surface_pending_operator_mail "telos"

  while true; do
    # step 1: tend (gardener assesses, may write new goals) — only when due
    local tended_this_iter=false
    if (( iter % tend_every == 0 )); then
      echo "telos: cycle [$iter] tending garden..."
      "$REPO_ROOT/scripts/personalagentkit" tend
      tended_this_iter=true
    fi

    # step 2: scan root goals/ for pending goals
    # pending = goal file NNN-*.md exists but no run dir (in root or any plant) with matching NNN prefix
    local best_nnn=999999
    local best_source=""   # "root" or plant name (from assigned_to)
    local best_goal_rel=""
    local blocked_count=0

    for goal_file in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md; do
      [[ -f "$goal_file" ]] || continue
      local base nnn nnn_int
      base=$(basename "$goal_file" .md)
      nnn=$(echo "$base" | grep -oE '^[0-9]+' | head -1)
      [[ -n "$nnn" ]] || continue
      nnn_int=$((10#$nnn))

      # Check if already run: look in root runs/ AND all plant runs/
      local has_run=false
      local d
      for d in "$REPO_ROOT/runs/${nnn}"-*/; do
        [[ -d "$d" ]] && { has_run=true; break; }
      done
      if [[ "$has_run" == "false" ]]; then
        local pp
        for pp in "$REPO_ROOT/plants"/*/; do
          [[ -d "$pp" ]] || continue
          for d in "${pp}runs/${nnn}"-*/; do
            [[ -d "$d" ]] && { has_run=true; break 2; }
          done
        done
      fi
      [[ "$has_run" == "true" ]] && continue

      # Read frontmatter: assigned_to and depends_on
      local goal_assigned_to goal_depends_on
      goal_assigned_to=$(parse_goal_meta "$goal_file" assigned_to)
      goal_depends_on=$(parse_goal_meta "$goal_file" depends_on)

      # Check dependencies: skip (but count as pending-blocked) if any dep is unsatisfied
      if [[ -n "$goal_depends_on" ]]; then
        local deps_ok=true
        local dep
        while IFS= read -r dep; do
          dep=$(echo "$dep" | tr -d ' ')
          [[ -z "$dep" ]] && continue
          if ! is_dep_satisfied "$dep"; then
            deps_ok=false
            break
          fi
        done < <(echo "$goal_depends_on" | tr -d '[]' | tr ',' '\n')
        if [[ "$deps_ok" == "false" ]]; then
          blocked_count=$(( blocked_count + 1 ))
          continue
        fi
      fi

      # Check capability gap for the assigned plant (if any)
      if [[ -n "$goal_assigned_to" ]]; then
        if [[ -f "$REPO_ROOT/plants/${goal_assigned_to}/capability-gap.md" ]]; then
          echo "telos: cycle skipping $base — ${goal_assigned_to} has capability gap (see plants/${goal_assigned_to}/capability-gap.md)"
          continue
        fi
        # Verify assigned plant exists
        if [[ ! -d "$REPO_ROOT/plants/${goal_assigned_to}" ]]; then
          echo "telos: auto-scaffolding plant: $goal_assigned_to (for goal $base)"
          mkdir -p "$REPO_ROOT/plants/${goal_assigned_to}/goals" \
                   "$REPO_ROOT/plants/${goal_assigned_to}/runs" \
                   "$REPO_ROOT/plants/${goal_assigned_to}/memory"
          cp "$REPO_ROOT/MOTIVATION.md" "$REPO_ROOT/plants/${goal_assigned_to}/MOTIVATION.md"
        fi
      fi

      if (( nnn_int < best_nnn )); then
        best_nnn=$nnn_int
        best_source="${goal_assigned_to:-root}"
        best_goal_rel="goals/$base.md"
      fi
    done

    # step 3: if no runnable pending goals, stop (with tend fallback if we skipped tend this iter)
    if [[ -z "$best_source" ]]; then
      if (( blocked_count > 0 )); then
        echo "telos: cycle stalled — $blocked_count goal(s) pending but blocked by unmet dependencies"
        break
      fi
      if [[ "$tended_this_iter" == "false" ]]; then
        echo "telos: cycle [$iter] queue empty — tending now to check for new goals..."
        "$REPO_ROOT/scripts/personalagentkit" tend
        tended_this_iter=true
        # re-scan after fallback tend
        best_nnn=999999
        best_source=""
        best_goal_rel=""
        blocked_count=0
        for goal_file in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md; do
          [[ -f "$goal_file" ]] || continue
          local base nnn nnn_int
          base=$(basename "$goal_file" .md)
          nnn=$(echo "$base" | grep -oE '^[0-9]+' | head -1)
          [[ -n "$nnn" ]] || continue
          nnn_int=$((10#$nnn))
          local has_run=false
          local d
          for d in "$REPO_ROOT/runs/${nnn}"-*/; do
            [[ -d "$d" ]] && { has_run=true; break; }
          done
          if [[ "$has_run" == "false" ]]; then
            local pp
            for pp in "$REPO_ROOT/plants"/*/; do
              [[ -d "$pp" ]] || continue
              for d in "${pp}runs/${nnn}"-*/; do
                [[ -d "$d" ]] && { has_run=true; break 2; }
              done
            done
          fi
          [[ "$has_run" == "true" ]] && continue
          local goal_assigned_to goal_depends_on
          goal_assigned_to=$(parse_goal_meta "$goal_file" assigned_to)
          goal_depends_on=$(parse_goal_meta "$goal_file" depends_on)
          if [[ -n "$goal_depends_on" ]]; then
            local deps_ok=true
            local dep
            while IFS= read -r dep; do
              dep=$(echo "$dep" | tr -d ' ')
              [[ -z "$dep" ]] && continue
              if ! is_dep_satisfied "$dep"; then
                deps_ok=false
                break
              fi
            done < <(echo "$goal_depends_on" | tr -d '[]' | tr ',' '\n')
            if [[ "$deps_ok" == "false" ]]; then
              blocked_count=$(( blocked_count + 1 ))
              continue
            fi
          fi
          if [[ -n "$goal_assigned_to" ]]; then
            if [[ -f "$REPO_ROOT/plants/${goal_assigned_to}/capability-gap.md" ]]; then
              continue
            fi
            if [[ ! -d "$REPO_ROOT/plants/${goal_assigned_to}" ]]; then
              continue
            fi
          fi
          if (( nnn_int < best_nnn )); then
            best_nnn=$nnn_int
            best_source="${goal_assigned_to:-root}"
            best_goal_rel="goals/$base.md"
          fi
        done
      fi
      if [[ -z "$best_source" ]]; then
        echo "telos: cycle complete — garden is quiet after $iter goal(s) run"
        break
      fi
    fi

    # step 4: check iteration cap
    if (( iter >= max_iter )); then
      echo "telos: cycle cap reached ($iter/$max_iter), pending goals remain — run ./personalagentkit cycle again to continue"
      break
    fi

    # step 5: classify goal type and check for repetition loop
    local goal_slug goal_type
    goal_slug=$(basename "$best_goal_rel" .md)
    goal_type=$(classify_goal_type "$goal_slug")

    if [[ "$goal_type" == "$last_goal_type" ]]; then
      consecutive_type_count=$(( consecutive_type_count + 1 ))
    else
      consecutive_type_count=1
      last_goal_type="$goal_type"
    fi

    if (( consecutive_type_count >= 6 )) && [[ "$goal_type" != "tend" && "$goal_type" != "retrospective" ]]; then
      echo "telos: cycle loop detected — $consecutive_type_count consecutive '$goal_type' goals"
      echo "telos: stopping to prevent spin. Commission a different goal type to continue."
      break
    fi

    # step 6: run the best pending goal — route based on assigned_to
    echo "telos: cycle [$iter/$max_iter] → $best_source/$best_goal_rel ($goal_type)"
    if [[ "$best_source" == "root" ]]; then
      "$REPO_ROOT/scripts/personalagentkit" run "$best_goal_rel"
    else
      "$REPO_ROOT/scripts/personalagentkit" plant-run "$best_source" "$best_goal_rel"
    fi

    # step 7: check cost cap
    if [[ -n "$max_cost" ]]; then
      local run_goal_id run_meta run_cost
      run_goal_id=$(basename "$best_goal_rel" .md)
      if [[ "$best_source" == "root" ]]; then
        run_meta="$REPO_ROOT/runs/$run_goal_id/meta.json"
      else
        run_meta="$REPO_ROOT/plants/$best_source/runs/$run_goal_id/meta.json"
      fi
      run_cost=$(jq -r '.cost.actual_usd // 0' "$run_meta" 2>/dev/null || echo 0)
      cycle_cost=$(echo "$cycle_cost + $run_cost" | bc)
      if (( $(echo "$cycle_cost >= $max_cost" | bc) )); then
        local actual_fmt max_fmt
        actual_fmt=$(printf '%.2f' "$cycle_cost")
        max_fmt=$(printf '%.2f' "$max_cost")
        echo "telos: cycle cost cap reached (\$$actual_fmt / \$$max_fmt), pending goals remain — run ./personalagentkit cycle again to continue"
        break
      fi
    fi

    # step 8: increment and loop
    iter=$(( iter + 1 ))
  done

  # ── post-cycle: schedule a retrospective ────────────────────────────────────
  # Find the next available NNN across goals/ and runs/
  local max_nnn=0
  for f in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md \
            "$REPO_ROOT/runs"/[0-9][0-9][0-9]-*/; do
    [[ -e "$f" ]] || continue
    local bn nnn
    bn=$(basename "$f" .md)
    nnn=$(echo "$bn" | grep -oE '^[0-9]+' | head -1)
    [[ -n "$nnn" ]] && (( 10#$nnn > max_nnn )) && max_nnn=$((10#$nnn))
  done
  local next_nnn
  next_nnn=$(printf '%03d' $(( max_nnn + 1 )))
  local retro_file="$REPO_ROOT/goals/${next_nnn}-retrospective.md"

  cat > "$retro_file" <<'RETRO'
# Goal: Retrospective

## What

Write a retrospective on what happened since the last retrospective. Assess the current
state of the garden, write a report, and convert your top recommendations into concrete
goal stubs that the next cycle can execute.

## How

1. Read `memory/MEMORY.md` and the most recent retrospective file under `memory/`
   for context on prior state.
2. Run `./personalagentkit garden` and `./personalagentkit status` to see what ran.
3. Read recent run outputs and reflections across all plants. Look especially for:
   - Loops: same goal type repeating more than 3 times in a row
   - Idle plants: plants with no recent goals despite having unresolved threads
   - Needs-human signals: `needs-human.md` files in any plant's latest run directory
4. Write a new dated section to `memory/retrospective.md` covering:
   - What was accomplished
   - Patterns or problems observed (be honest — name loops directly)
   - 3 concrete recommendations for the next cycle
5. For each recommendation, write a draft goal stub:
   - Find the next available NNN by scanning `goals/` and `runs/`
   - Write `goals/NNN-<slug>.md` with a brief goal description
   - These become real goals the cycle will pick up and run
6. Your final message is your summary to the operator — include which goal stubs were written.

## Definition of done

- `memory/retrospective.md` updated with a dated section
- Up to 3 goal stubs written to `goals/NNN-*.md`

## Constraints

- Goal stubs must be actionable (not "improve quality" — name the specific file and change)
- If a recommendation requires human input, write the stub anyway and note it in the goal
- Don't write a stub for "do another retrospective" — that happens automatically
- **Do NOT make a terminal commit** with a message like `run {id}: finalize`. The runner
  commits everything after you exit. Use descriptive intermediate commits only.
RETRO

  echo "telos: running post-cycle retrospective → $retro_file"
  "$REPO_ROOT/scripts/personalagentkit" run "goals/${next_nnn}-retrospective.md"
}

cmd_submit() {
  local plant_name="" depends_on="" submitted_by="${TELOS_SUBMITTED_BY:-}" priority="" driver="" model="" goal_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plant)        plant_name="$2";    shift 2 ;;
      --depends-on)   depends_on="$2";    shift 2 ;;
      --submitted-by) submitted_by="$2";  shift 2 ;;
      --priority)     priority="$2";      shift 2 ;;
      --driver)       driver="$2";        shift 2 ;;
      --model)        model="$2";         shift 2 ;;
      *)              goal_file="$1";     shift ;;
    esac
  done

  [[ -n "$goal_file" ]] || die "usage: personalagentkit submit [--plant <name>] [--depends-on <slug,...>] [--driver <name>] [--model <name>] <goal-file>"
  [[ -f "$goal_file" ]] || die "goal file not found: $goal_file"

  if [[ -n "$plant_name" ]]; then
    [[ -d "$REPO_ROOT/plants/$plant_name" ]] || die "plant not found: plants/$plant_name"
  fi

  # Auto-increment NNN across root goals/, root runs/, and all plant runs/
  local max_n=0
  local f nnn
  for f in "$REPO_ROOT/goals"/[0-9][0-9][0-9]-*.md \
            "$REPO_ROOT/runs"/[0-9][0-9][0-9]-*/; do
    [[ -e "$f" ]] || continue
    nnn=$(basename "${f%.md}" | grep -oE '^[0-9]+' | head -1)
    [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
  done
  local plant_path
  for plant_path in "$REPO_ROOT/plants"/*/; do
    for f in "${plant_path}runs"/[0-9][0-9][0-9]-*/; do
      [[ -d "$f" ]] || continue
      nnn=$(basename "$f" | grep -oE '^[0-9]+' | head -1)
      [[ -n "$nnn" ]] && (( 10#$nnn > max_n )) && max_n=$((10#$nnn))
    done
  done
  local goal_num
  goal_num=$(printf "%03d" $(( max_n + 1 )))

  # Derive slug from source filename (strip leading NNN- prefix if present)
  local goal_slug
  goal_slug=$(basename "$goal_file" .md | sed 's/^[0-9]*-//')
  local dest="$REPO_ROOT/goals/${goal_num}-${goal_slug}.md"

  # Extract body and existing frontmatter from source file
  local body first_line src_assigned="" src_depends="" src_submitted="" src_priority="" src_driver="" src_model=""
  first_line=$(head -1 "$goal_file")
  if [[ "$first_line" == "---" ]]; then
    # Parse existing frontmatter values
    local fm_block
    fm_block=$(awk '/^---$/{n++; if(n==2) exit} n==1{print}' "$goal_file")
    src_assigned=$(echo "$fm_block"  | grep '^assigned_to:'  | head -1 | cut -d: -f2- | xargs || true)
    src_depends=$(echo "$fm_block"   | grep '^depends_on:'   | head -1 | cut -d: -f2- | xargs || true)
    src_submitted=$(echo "$fm_block" | grep '^submitted_by:' | head -1 | cut -d: -f2- | xargs || true)
    src_priority=$(echo "$fm_block"  | grep '^priority:'     | head -1 | cut -d: -f2- | xargs || true)
    src_driver=$(echo "$fm_block"    | grep '^driver:'       | head -1 | cut -d: -f2- | xargs || true)
    src_model=$(echo "$fm_block"     | grep '^model:'        | head -1 | cut -d: -f2- | xargs || true)
    body=$(awk 'BEGIN{f=0} /^---$/{f++; if(f==2){found=1; next}} found{print}' "$goal_file")
  else
    body=$(cat "$goal_file")
  fi

  # CLI flags override source frontmatter
  [[ -n "$plant_name" ]]   && src_assigned="$plant_name"
  [[ -n "$depends_on" ]]   && src_depends="[$depends_on]"
  [[ -n "$submitted_by" ]] && src_submitted="$submitted_by"
  [[ -n "$priority" ]]     && src_priority="$priority"
  [[ -n "$driver" ]]       && src_driver="$driver"
  [[ -n "$model" ]]        && src_model="$model"

  # Normalize depends_on format
  [[ -n "$src_depends" ]] && src_depends=$(echo "$src_depends" | sed 's/^\[//;s/\]$//')

  # Write destination file with merged frontmatter
  {
    if [[ -n "$src_assigned" || -n "$src_depends" || -n "$src_submitted" || -n "$src_priority" || -n "$src_driver" || -n "$src_model" ]]; then
      echo "---"
      [[ -n "$src_assigned" ]]  && echo "assigned_to: $src_assigned"
      [[ -n "$src_depends" ]]   && echo "depends_on: [$src_depends]"
      [[ -n "$src_submitted" ]] && echo "submitted_by: $src_submitted"
      [[ -n "$src_priority" ]]  && echo "priority: $src_priority"
      [[ -n "$src_driver" ]]    && echo "driver: $src_driver"
      [[ -n "$src_model" ]]     && echo "model: $src_model"
      echo "---"
    fi
    echo "$body"
  } > "$dest"

  (
    flock -x 200
    git -C "$REPO_ROOT" add "$dest" 2>/dev/null
    git -C "$REPO_ROOT" commit -m "goal: ${goal_num}-${goal_slug}" 2>/dev/null || true
  ) 200>"$REPO_ROOT/.personalagentkit-git.lock"

  write_goal_run_pointer "goals/${goal_num}-${goal_slug}.md"
  echo "submitted: goals/${goal_num}-${goal_slug}.md"
}

cmd_await() {
  local goal_id="" timeout=300

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) timeout="$2"; shift 2 ;;
      *)         goal_id="$1"; shift ;;
    esac
  done

  [[ -n "$goal_id" ]] || die "usage: personalagentkit await <goal-id> [--timeout <seconds>]"

  local elapsed=0
  echo "telos: await $goal_id (timeout=${timeout}s)"

  while (( elapsed < timeout )); do
    local meta=""
    # Check root runs
    local run_dir
    for run_dir in "$REPO_ROOT/runs/${goal_id}"*/; do
      [[ -f "${run_dir}meta.json" ]] && { meta="${run_dir}meta.json"; break; }
    done
    # Check plant runs if not found in root
    if [[ -z "$meta" ]]; then
      local plant_path
      for plant_path in "$REPO_ROOT/plants"/*/; do
        for run_dir in "${plant_path}runs/${goal_id}"*/; do
          [[ -f "${run_dir}meta.json" ]] && { meta="${run_dir}meta.json"; break 2; }
        done
      done
    fi

    if [[ -n "$meta" ]]; then
      local status
      status=$(jq -r '.status // ""' "$meta" 2>/dev/null)
      status=$(normalize_status "$status")
      if [[ "$status" == "success" ]]; then
        echo "telos: await $goal_id → success"
        return 0
      elif is_terminal_status "$status"; then
        echo "telos: await $goal_id → $status"
        return 1
      fi
    fi

    sleep 10
    elapsed=$(( elapsed + 10 ))
  done

  echo "telos: await $goal_id → timeout after ${timeout}s"
  return 2
}

cmd_watch() {
  trap 'printf "\npersonalagentkit: done\n"; exit 0' INT TERM

  while true; do
    printf '\033[2J\033[H'
    printf 'personalagentkit: watching... (ctrl-c to stop)\n\n'

    local now_epoch
    now_epoch=$(date +%s)
    local found=false

    # Collect all running runs from root + all plants
    local meta
    for meta in \
        "$REPO_ROOT/runs"/*/meta.json \
        "$REPO_ROOT/plants"/*/runs/*/meta.json; do
      [[ -f "$meta" ]] || continue
      local status_raw
      status_raw=$(jq -r '.status // ""' "$meta" 2>/dev/null)
      [[ "$status_raw" == "running" ]] || continue
      found=true

      local run_id started_at
      run_id=$(jq -r '.run_id // ""' "$meta" 2>/dev/null)
      started_at=$(jq -r '.started_at // ""' "$meta" 2>/dev/null)

      local started_epoch elapsed em es
      started_epoch=$(iso_to_epoch "$started_at")
      elapsed=$(( now_epoch - started_epoch ))
      em=$(( elapsed / 60 ))
      es=$(( elapsed % 60 ))

      local events_file event_count
      events_file="$(dirname "$meta")/events.jsonl"
      event_count=0
      [[ -f "$events_file" ]] && event_count=$(wc -l < "$events_file" 2>/dev/null | tr -d ' ' || echo 0)

      # Build display id: plant/run-id or run-id
      local display_id
      if [[ "$meta" == *"/plants/"* ]]; then
        local plant_name
        plant_name=$(echo "$meta" | sed 's|.*/plants/\([^/]*\)/.*|\1|')
        display_id="${plant_name}/${run_id}"
      else
        display_id="$run_id"
      fi

      printf '  %-40s  %dm %02ds   %s events\n' "$display_id" "$em" "$es" "$event_count"
    done

    if [[ "$found" == "false" ]]; then
      printf '  (no running goals)\n'
    fi

    sleep 3
  done
}

cmd_priority() {
  local goal_id="${1:-}" priority="${2:-}"
  [[ -n "$goal_id" && -n "$priority" ]] || die "usage: personalagentkit priority <goal-id> <N>"
  local goal_file
  goal_file=$(ls "$REPO_ROOT/goals/${goal_id}"*.md 2>/dev/null | head -1)
  [[ -n "$goal_file" && -f "$goal_file" ]] || die "goal not found: $goal_id"
  python3 - "$goal_file" "$priority" <<'PYEOF'
import sys, re
path, priority = sys.argv[1], sys.argv[2]
with open(path) as f:
    content = f.read()
if content.startswith('---'):
    # frontmatter exists — update or insert priority
    parts = content.split('---', 2)
    fm = parts[1]
    if re.search(r'^priority:', fm, re.MULTILINE):
        fm = re.sub(r'^priority:.*$', f'priority: {priority}', fm, flags=re.MULTILINE)
    else:
        fm = fm.rstrip('\n') + f'\npriority: {priority}\n'
    content = '---' + fm + '---' + parts[2]
else:
    content = f'---\npriority: {priority}\n---\n' + content
with open(path, 'w') as f:
    f.write(content)
PYEOF
  (
    flock -x 200
    git -C "$REPO_ROOT" add "$goal_file" 2>/dev/null
    git -C "$REPO_ROOT" commit -m "priority: $goal_id → $priority" 2>/dev/null || true
  ) 200>"$REPO_ROOT/.personalagentkit-git.lock"
  echo "telos: priority set → $goal_file (priority: $priority)"
}

cmd_cancel() {
  local goal_id="${1:-}"
  [[ -n "$goal_id" ]] || die "usage: personalagentkit cancel <goal-id>"
  local goal_file
  goal_file=$(ls "$REPO_ROOT/goals/${goal_id}"*.md 2>/dev/null | head -1)
  [[ -n "$goal_file" && -f "$goal_file" ]] || die "goal not found: $goal_id"
  local cancelled="${goal_file%.md}.cancelled"
  mv "$goal_file" "$cancelled"
  (
    flock -x 200
    git -C "$REPO_ROOT" rm "$goal_file" 2>/dev/null || true
    git -C "$REPO_ROOT" add "$cancelled" 2>/dev/null
    git -C "$REPO_ROOT" commit -m "cancel: $goal_id" 2>/dev/null || true
  ) 200>"$REPO_ROOT/.personalagentkit-git.lock"
  echo "telos: cancelled → $cancelled"
}

cmd_pause() {
  touch "$REPO_ROOT/.personalagentkit-pause"
  echo "telos: pause sentinel set (.personalagentkit-pause)"
}

cmd_stop() {
  touch "$REPO_ROOT/.personalagentkit-stop"
  echo "telos: stop sentinel set (.personalagentkit-stop)"
}

cmd_publish_github() {
  require git
  require curl
  require jq

  local cli_remote="" cli_head="" cli_base="" cli_owner="" cli_repo=""
  local cli_title="" cli_body="" cli_draft=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --remote) [[ -n "${2:-}" ]] || die "--remote requires a value"; cli_remote="$2"; shift 2 ;;
      --head) [[ -n "${2:-}" ]] || die "--head requires a value"; cli_head="$2"; shift 2 ;;
      --base) [[ -n "${2:-}" ]] || die "--base requires a value"; cli_base="$2"; shift 2 ;;
      --owner) [[ -n "${2:-}" ]] || die "--owner requires a value"; cli_owner="$2"; shift 2 ;;
      --repo) [[ -n "${2:-}" ]] || die "--repo requires a value"; cli_repo="$2"; shift 2 ;;
      --title) [[ -n "${2:-}" ]] || die "--title requires a value"; cli_title="$2"; shift 2 ;;
      --body) [[ -n "${2:-}" ]] || die "--body requires a value"; cli_body="$2"; shift 2 ;;
      --draft) cli_draft="true"; shift ;;
      --help|-h) github_usage; exit 0 ;;
      --*) die "unknown argument: $1" ;;
      *) die "unknown argument: $1" ;;
    esac
  done

  local config_file token_file
  config_file="$(github_config_file)"
  token_file="$(github_token_file)"
  github_load_config "$config_file"

  GITHUB_READ_TOKEN_RESULT=""
  github_read_token "$token_file" || {
    local token_status=$?
    [[ "$token_status" -eq 10 ]] && return 0
    return "$token_status"
  }
  local token="$GITHUB_READ_TOKEN_RESULT"

  local remote="${cli_remote:-${GITHUB_REMOTE:-origin}}"
  local head_branch="${cli_head:-$(github_current_branch)}"
  local base_branch="${cli_base:-${GITHUB_BASE_BRANCH:-}}"
  local owner="${cli_owner:-${GITHUB_REPO_OWNER:-}}"
  local repo="${cli_repo:-${GITHUB_REPO_NAME:-}}"
  local title="${cli_title:-${GITHUB_PR_TITLE:-Publish $head_branch}}"
  local body="${cli_body:-${GITHUB_PR_BODY:-}}"
  local draft
  draft="$(github_normalize_bool "${cli_draft:-${GITHUB_PR_DRAFT:-false}}")"
  local api_base_url="${GITHUB_API_BASE_URL:-https://api.github.com}"

  [[ -n "$owner" ]] || die "GITHUB_REPO_OWNER is required in $config_file or via --owner"
  [[ -n "$repo" ]] || die "GITHUB_REPO_NAME is required in $config_file or via --repo"
  [[ -n "$base_branch" ]] || die "GITHUB_BASE_BRANCH is required in $config_file or via --base"
  [[ -n "$head_branch" && "$head_branch" != "HEAD" ]] || die "current branch is detached; pass --head explicitly"

  local request_json
  request_json="$(jq -n \
    --arg title "$title" \
    --arg head "$head_branch" \
    --arg base "$base_branch" \
    --arg body "$body" \
    --argjson draft "$draft" \
    '{title: $title, head: $head, base: $base, body: $body, draft: $draft}')"

  github_push_branch "$remote" "$head_branch" "$token"

  local response pr_url
  response="$(github_create_pr "$api_base_url" "$owner" "$repo" "$token" "$request_json")"
  pr_url="$(printf '%s' "$response" | jq -r '.html_url // empty')"

  if [[ -n "$pr_url" ]]; then
    echo "personalagentkit: publish-github pushed $head_branch to $remote and opened PR: $pr_url"
  else
    echo "personalagentkit: publish-github pushed $head_branch to $remote and created pull request via $api_base_url/repos/$owner/$repo/pulls"
    printf '%s\n' "$response"
  fi
}

cmd_resume() {
  rm -f "$REPO_ROOT/.personalagentkit-pause" "$REPO_ROOT/.personalagentkit-stop"
  echo "telos: sentinels cleared"
}

cmd_resume_run() {
  local run_id="${1:-}"
  [[ -n "$run_id" ]] || die "usage: personalagentkit resume-run <run-id>"

  require python3
  require jq

  local run_dir
  run_dir=$(find_run_dir_by_id "$run_id") || die "run not found: $run_id"
  local meta="$run_dir/meta.json"
  local status
  status=$(jq -r '.status // ""' "$meta" 2>/dev/null)
  status=$(normalize_status "$status")
  [[ "$status" == "killed" ]] || die "resume-run currently only supports killed runs; found status: $status"

  local goal_file driver model goal_type requires_reflection base_dir
  goal_file=$(jq -r '.goal_file // empty' "$meta" 2>/dev/null)
  driver=$(jq -r '.driver // empty' "$meta" 2>/dev/null)
  model=$(jq -r '.model // empty' "$meta" 2>/dev/null)
  goal_type=$(jq -r '.goal_type // "build"' "$meta" 2>/dev/null)
  requires_reflection=$(jq -r '.requires_reflection // false' "$meta" 2>/dev/null)

  [[ -n "$goal_file" && -f "$REPO_ROOT/$goal_file" ]] || die "goal file missing for run: $goal_file"
  [[ -n "$driver" && -n "$model" ]] || die "run meta missing driver/model: $run_id"

  resolve_driver_config "$driver" "$model"
  require "$_driver_bin"

  if [[ "$run_dir" == "$REPO_ROOT/plants/"*"/runs/"* ]]; then
    base_dir="$(dirname "$(dirname "$run_dir")")"
  else
    base_dir="$REPO_ROOT"
  fi

  local prior_attempt archive_dir resumed_at attempt prompt
  prior_attempt=$(current_attempt_number "$run_dir")
  [[ "$prior_attempt" -gt 0 ]] || die "cannot resume run without an existing attempt prompt artifact: $run_id"

  archive_dir=$(archive_attempt_artifacts "$run_dir" "$prior_attempt")
  resumed_at=$(iso_now)
  reset_meta_for_resume "$meta" "$resumed_at" "$prior_attempt"
  write_run_readme "$run_dir"

  attempt=$(next_attempt_number "$run_dir")
  prompt=$(build_run_prompt \
    "$goal_file" \
    "$base_dir" \
    "$goal_type" \
    "$requires_reflection" \
    "$(resume_context_block "$run_dir" "$prior_attempt" "$archive_dir")")
  write_prompt_artifact "$run_dir" "$attempt" "$prompt"
  append_checkpoint "$run_dir" "resumed" "prior_attempt=$(attempt_label "$prior_attempt") basis=local-artifacts provider_continuation=false"

  invoke_agent "$run_dir" "$prompt"
  local driver_result_json="$DRIVER_RESULT_JSON"
  local completed_at

  persist_driver_result_to_meta "$meta" "$run_dir" "$driver_result_json"
  write_run_transcript "$run_dir"
  write_run_readme "$run_dir"
  completed_at=$(jq -r '.completed_at // empty' "$meta" 2>/dev/null)
  write_resume_artifact "$run_dir" "$prior_attempt" "$archive_dir"

  echo "personalagentkit: resumed run $run_id as attempt $(attempt_label "$attempt")"
  echo "personalagentkit: completed at $completed_at with status $(jq -r '.status' "$meta")"
  echo "personalagentkit: resumption record → $run_dir/resume.md"
}

cmd_help() {
  cat <<'HELP'
personalagentkit — minimal goal runner

Commands:
  run [--driver D] [--model M] <goal-file>
                             Run a goal, record what happened
  status                     Show in-flight runs at top, then all root run records
  watch                      Live-updating table of in-flight runs (ctrl-c to stop)
  plant <seed> <name>        Create a new plant from a seed and run its genesis goal
  plant-run [--driver D] [--model M] <name> <goal>
                             Run a subsequent goal within a plant (injects plant memory)
  garden                     Show the state of all plants
  tend                       Write a tend goal for head-gardener and run it
  retrospective              Write a retrospective goal for gardener and run it
  regenesis <plant> [seed]   Re-inject updated seed into a plant's memory
  publish-github             Push the current branch and open a pull request via config/github.env
  resume-run <run-id>        Resume a killed run from local artifacts with a fresh provider call
  submit [--plant <name>] [--depends-on <slug,...>] [--priority N] [--driver D] [--model M] <goal-file>
                             Write a goal to goals/ with frontmatter; exits immediately
  await <goal-id> [--timeout <seconds>]
                             Poll until a goal run reaches a terminal status: success, failure, killed, or abandoned (default: 300s)
  cycle [--workers N] [--tend-interval SECONDS] [--retro-interval SECONDS] [--max-cost <dollars>] [--fg]
                             Concurrent dispatcher: auto-launches in tmux (use --fg to stay in foreground)
  priority <goal-id> <N>     Set priority (lower = sooner; default 5)
  cancel <goal-id>           Remove goal from queue (renames to .cancelled)
  pause                      Signal dispatcher to pause after current batch
  stop                       Signal dispatcher to exit after current goals finish
  restart                    Stop cleanly, then restart cycle with same parameters
  resume                     Clear pause/stop sentinels
  help                       Show this message

Run records (runs/NNN-slug/):
  meta.json       Structured run record; status is one of: running | success | failure | killed | abandoned
  events.jsonl    NDJSON stream of claude events (tail -f while running for live view)
  transcript.md   Terminal-only reader aid derived from events.jsonl + meta.json
  _stdout.md       Final agent text output extracted from the result event
  stderr.txt      stderr from the claude process

  status: killed  Set when the no-event watchdog fires; partial cost data preserved
  legacy read-compat: completed->success, failed->failure; new runs write only canonical statuses
  New runs also record goal_type and requires_reflection so reflection obligations are explicit.

Goal frontmatter (optional YAML block at top of goal file):
  ---
  assigned_to: first-coder    # route to a plant (must match plants/<name>)
  depends_on: [003-build-x]   # wait until these goal slugs have a successful run
                               # or use 003-build-x:done|success|failure|killed|abandoned
  priority: 5                 # 1=urgent, 10=someday, default 5 (lower runs sooner)
  driver: codex               # optional per-goal driver override
  model: codex-mini-latest    # optional per-goal model override
  ---

Driver routing contract:
  Route multi-driver work with goal frontmatter plus normal dispatch.
  Do not launch nested `./scripts/personalagentkit run ...` from inside an active run.
  If you need a one-off bypass for debugging, set PAK_ALLOW_NESTED_RUN=1 explicitly.

Examples:
  ./personalagentkit run goals/002-something.md
  ./personalagentkit run goals/002-something.md --driver codex --model codex-mini-latest
  ./personalagentkit status
  ./personalagentkit watch
  ./personalagentkit plant coder first-coder
  ./personalagentkit plant-run first-coder goals/002-next.md
  ./personalagentkit garden
  ./personalagentkit tend
  ./personalagentkit publish-github
  ./personalagentkit submit --plant first-coder /tmp/my-goal.md
  ./personalagentkit submit --plant explorer --depends-on 012-build-lib --priority 3 --driver codex --model gpt-5.4 /tmp/spike.md
  ./personalagentkit await 013-my-goal
  ./personalagentkit await 013-my-goal --timeout 600
  ./personalagentkit cycle
  ./personalagentkit cycle --workers 3 --tend-interval 120
  ./personalagentkit cycle --workers 2 --max-cost 5.00
  ./personalagentkit priority 007-fix-bug 2
  ./personalagentkit cancel 007-fix-bug
  ./personalagentkit pause
  ./personalagentkit stop
  ./personalagentkit resume
HELP
}

# ── dispatch ──────────────────────────────────────────────────────────────────

case "${1:-help}" in
  run)        shift; cmd_run "$@" ;;
  status)     cmd_status ;;
  watch)      cmd_watch ;;
  plant)      shift; cmd_plant "$@" ;;
  plant-run)  shift; cmd_plant_run "$@" ;;
  garden)     cmd_garden ;;
  tend)       cmd_tend ;;
  retrospective) cmd_retrospective ;;
  regenesis)  shift; cmd_regenesis "$@" ;;
  publish-github) shift; cmd_publish_github "$@" ;;
  resume-run) shift; cmd_resume_run "$@" ;;
  submit)     shift; cmd_submit "$@" ;;
  await)      shift; cmd_await "$@" ;;
  cycle)      shift; cmd_cycle "$@" ;;
  priority)   shift; cmd_priority "$@" ;;
  cancel)     shift; cmd_cancel "$@" ;;
  pause)      cmd_pause ;;
  stop)       cmd_stop ;;
  restart)    cmd_restart ;;
  resume)     cmd_resume ;;
  help)       cmd_help ;;
  *)          die "unknown command: $1 (try: personalagentkit help)" ;;
esac
